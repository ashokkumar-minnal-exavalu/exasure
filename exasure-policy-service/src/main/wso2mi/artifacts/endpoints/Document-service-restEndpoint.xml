<?xml version="1.0" encoding="UTF-8"?>
<endpoint name="Document-service-restEndpoint" xmlns="http://ws.apache.org/ns/synapse">
    <address uri="${configs.DOCUMENT_SERVICE_RESTENDPOINT_URI}">
        <suspendOnFailure>
            <initialDuration>-1</initialDuration>
            <progressionFactor>1</progressionFactor>
        </suspendOnFailure>
        <markForSuspension>
            <retriesBeforeSuspension>0</retriesBeforeSuspension>
        </markForSuspension>
    </address>
</endpoint>
