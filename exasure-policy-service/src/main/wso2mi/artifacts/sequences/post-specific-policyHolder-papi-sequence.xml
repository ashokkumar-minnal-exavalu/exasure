<?xml version="1.0" encoding="UTF-8"?>
<sequence name="post-specific-policyHolder-papi-sequence" trace="disable" xmlns="http://ws.apache.org/ns/synapse">
            <property name="CorrelationID" expression="get-property('correlation_id')"/>
            <property name="LatencyMs" scope="default" type="STRING" value="0"/>
            <!-- Start time for latency -->
            <property name="StartTime" expression="get-property('SYSTEM_TIME')"/>
            <call-template target="Common-Log-Template-V1">
                <with-param name="service" value="policyHolder-api"/>
                <with-param name="sequence" value="post-specific-policyHolder-papi-sequence"/>
                <with-param name="level" value="INFO"/>
                <with-param name="message" value="Started post-specific-policyHolder-papi-sequence"/>
                <with-param name="status" value="START"/>
            </call-template>            
            <property name="Input-Payload" scope="default" type="STRING" expression="json-eval($)"/>
            <property name="policyHolderId" expression="fn:concat('PH', get-property('SYSTEM_TIME'))" scope="default" type="STRING"/>
            <property name="createdTimestamp" expression="get-property('SYSTEM_DATE')" scope="default" type="STRING"/>
            <property name="updatedTimestamp" expression="get-property('createdTimestamp')" scope="default" type="STRING"/>
            <payloadFactory media-type="json">
                <format>
                                {
                                "statusCode": 200,
                                "statusMessage": "policy holder Created",
                                "policyHolderId": "$1",
                                "createdTimestamp": "$2",
                                "updatedTimestamp": "$3",
                                "policyHolderDetails": {
                                "firstName": "$4",
                                "lastName": "$5",
                                "email": "$6",
                                "gender": "$7",
                                "dateOfBirth": "$8",
                                "occupation": "$9",
                                "maritalStatus": "$10",
                                "address": {
                                "country": "$11",
                                "state": "$12",
                                "zipCode": "$13"
                                }
                                }
                                }
                </format>

                <args>
                    <arg evaluator="xml" expression="get-property('policyHolderId')"/>
                    <arg evaluator="xml" expression="get-property('createdTimestamp')"/>
                    <arg evaluator="xml" expression="get-property('updatedTimestamp')"/>
                    <arg evaluator="json" expression="$.policyHolderDetails.firstName"/>
                    <arg evaluator="json" expression="$.policyHolderDetails.lastName"/>
                    <arg evaluator="json" expression="$.policyHolderDetails.email"/>
                    <arg evaluator="json" expression="$.policyHolderDetails.gender"/>
                    <arg evaluator="json" expression="$.policyHolderDetails.dateOfBirth"/>
                    <arg evaluator="json" expression="$.policyHolderDetails.occupation"/>
                    <arg evaluator="json" expression="$.policyHolderDetails.maritalStatus"/>
                    <arg evaluator="json" expression="$.policyHolderDetails.address.country"/>
                    <arg evaluator="json" expression="$.policyHolderDetails.address.state"/>
                    <arg evaluator="json" expression="$.policyHolderDetails.address.zipCode"/>
                </args>
            </payloadFactory>
            <propertyGroup description="inputProperty">
                <property name="HTTP_METHOD" scope="axis2" type="STRING" value="POST"/>
                <property name="REST_URL_POSTFIX" scope="axis2" type="STRING" expression="fn:concat('/api/', 'policyHolder')"/>
            </propertyGroup>
            <call>
                <endpoint key="policyHolder-sapi-restEndpoint"/>
            </call>            
            <property description="statusCode" expression="$axis2:HTTP_SC" name="statusCode" scope="default" type="STRING"/>   
            <filter xpath="get-property('statusCode')='200'">
                <then>
                    <payloadFactory description="Response poayload" media-type="json">
                        <format>
                            $1
                        </format>
                        <args>
                            <arg evaluator="json" expression="$"/>
                        </args>
                    </payloadFactory>
                </then>
                <else>
                    <propertyGroup description="error details">
                        <property expression="json-eval($.errors[0].errorCode)" name="ERROR_CODE" scope="default" type="STRING"/>
                        <property expression="json-eval($.errors[0].errorMessage)" name="ERROR_MESSAGE" scope="default" type="STRING"/>
                        <property expression="json-eval($.errors[0].errorDescription)" name="ERROR_DETAIL" scope="default" type="STRING"/>
                    </propertyGroup>
                    <call-template description="Error Log" target="Common-Log-Template-V1">
                        <with-param name="service" value="policyHolder-api"/>
                        <with-param name="sequence" value="post-specific-policyHolder-papi-sequence"/>
                        <with-param name="level" value="INFO"/>
                        <with-param name="message" value="{$ctx:ERROR_MESSAGE}"/> 
                        <with-param name="status" value="ERROR"/>
                    </call-template>                    
                    <sequence key="policyHolder-papi-fault-sequence"/>
                </else>
            </filter>
            <property name="LatencyMs" expression="get-property('SYSTEM_TIME') - get-property('StartTime')"/>    
            <call-template target="Common-Log-Template-V1">
                <with-param name="service" value="policyHolder-api"/>
                <with-param name="sequence" value="post-specific-policyHolder-papi-sequence"/>
                <with-param name="level" value="INFO"/>
                <with-param name="message" value="Ended post-specific-policyHolder-papi-sequence"/>
                <with-param name="status" value="END"/>
            </call-template>            
</sequence>