<?xml version="1.0" encoding="UTF-8"?>
<sequence name="policy-admin-papi-issue-endorsement-sequence" trace="disable" xmlns="http://ws.apache.org/ns/synapse">
    <propertyGroup description="apiProperty">
        <property name="CorrelationID" expression="get-property('correlation_id')"/>
        <property name="LatencyMs" scope="default" type="STRING" value="0"/>
        <property name="StartTime" expression="get-property('SYSTEM_TIME')"/>
        <property name="requestPayload" expression="json-eval($)"/>
        <property name="endorsementId" expression="get-property('uri.var.endorsementId')"/>
    </propertyGroup>
    <call-template target="Common-Log-Template-V1">
        <with-param name="service" value="policy-admin-papi"/>
        <with-param name="sequence" value="policy-admin-papi-issue-endorsement-sequence"/>
        <with-param name="level" value="INFO"/>
        <with-param name="message" value="Start policy-admin-papi-issue-endorsement-sequence"/>
        <with-param name="status" value="START"/>
    </call-template>
    <propertyGroup description="inputProperty">
        <property name="HTTP_METHOD" scope="axis2" type="STRING" value="GET"/>
        <property name="REST_URL_POSTFIX" scope="axis2" type="STRING" expression="fn:concat('/api/endorsements/', get-property('endorsementId'))"/>
    </propertyGroup>
    <call description="fetch documents by endorsementid">
        <endpoint key="endorsement-sapi-restEndpoint"/>
    </call>
    <property description="statusCode" expression="$axis2:HTTP_SC" name="statusCode" scope="default" type="STRING"/>
    <filter xpath="get-property('statusCode')='200'">
        <then>
    <property name="status" scope="default" type="STRING" expression="json-eval($.data[0].endorsementStatusCode)"/>       
    <filter xpath="get-property('status') = 'ACCEPTED'">
    <then>
<script language="js"><![CDATA[var payload = mc.getPayloadJSON();

var p = payload.data[0];

var old = p.policyVersion.policyVersionIdentifier.split("-")[1];

var newId = "PV-" + ("000" + (parseInt(old) + 1)).slice(-3);

var result = {
   endorsementStatusCode: "ISSUED",
   policyVersion: {
      versionNumber: parseInt(p.policyVersion.versionNumber) + 1,
      policyVersionIdentifier: newId
   }
};

mc.setProperty("policyAcceptUpdate", JSON.stringify(result));
]]></script>
<payloadFactory media-type="json">
   <format>
{
  "policyAcceptUpdate": $1,
  "documentTypeCode": "$2",
  "generatedDate": "$3"
}
   </format>
   <args>
      <arg evaluator="json" expression="$ctx:policyAcceptUpdate"/>
      <arg evaluator="json" expression="$ctx:requestPayload.document.documentTypeCode"/>
      <arg evaluator="json" expression="$ctx:requestPayload.policyEvent.eventDate"/>
   </args>
</payloadFactory>

<property name="messageType" value="application/json" scope="axis2"/>
<property name="ContentType" value="application/json" scope="axis2"/>

<propertyGroup description="inputProperty">
    <property name="HTTP_METHOD" scope="axis2" type="STRING" value="PATCH"/>
    <property name="REST_URL_POSTFIX" scope="axis2" type="STRING"
              expression="fn:concat('/api/endorsements/', get-property('endorsementId'), '/issue')"/>
</propertyGroup>
<log level="full">
    <property name="PATCH_PAYLOAD" expression="json-eval($)"/>
</log>
<call description="update issueEndorsement">
    <endpoint key="endorsement-sapi-restEndpoint"/>
</call>
    </then>
    <else>
    <filter xpath="get-property('status') = 'ISSUED'">
    <then>
    <payloadFactory media-type="json">
    <format>
                                    {
                                    "endorsementStatusCode": "$1",
                                    "processingStatus": "NO_ACTION_REQUIRED",
                                    "message": "Endorsement has already been issued; no further issuance is required."
                                    }
                                </format>
    <args>
        <arg evaluator="json" expression="$.data[0].endorsementStatusCode"/>
                                </args>
    </payloadFactory>
    </then>
    <else>
    <payloadFactory media-type="json">
    <format>
                                    {
                                    "errorCode": "ENDORSEMENT_INVALID_STATUS",
                                    "message": "Endorsement cannot be issued when the endorsementStatusCode is not ACCEPTED."
                                    }
                                </format>
    <args/>
                            </payloadFactory>
                        </else>
                    </filter>
                </else>
    </filter>
        </then>
        <else>
            <propertyGroup description="error details">
                <property value="404" name="ERROR_CODE" scope="default" type="STRING"/>
                <property value="Not Found" name="ERROR_MESSAGE" scope="default" type="STRING"/>
                <property value="Data not found for the given endorsementId" name="ERROR_DETAIL" scope="default" type="STRING"/>
            </propertyGroup>
            <call-template target="Common-Log-Template-V1">
                <with-param name="service" value="policy-admin-papi"/>
                <with-param name="sequence" value="policy-admin-papi-issue-endorsement-sequence"/>
                <with-param name="level" value="INFO"/>
                <with-param name="message" value="{$ctx:ERROR_MESSAGE}"/>
                <with-param name="status" value="ERROR"/>
            </call-template>
            <sequence key="policy-admin-papi-fault-sequence"/>
        </else>
    </filter>
    <property name="LatencyMs" expression="get-property('SYSTEM_TIME') - get-property('StartTime')"/>
    <call-template target="Common-Log-Template-V1">
        <with-param name="service" value="policy-admin-papi"/>
        <with-param name="sequence" value="policy-admin-papi-issue-endorsement-sequence"/>
        <with-param name="level" value="INFO"/>
        <with-param name="message" value="Ended policy-admin-papi-issue-endorsement-sequence"/>
        <with-param name="status" value="End"/>
    </call-template>
</sequence>