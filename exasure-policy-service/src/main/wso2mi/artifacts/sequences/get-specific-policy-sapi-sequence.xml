<?xml version="1.0" encoding="UTF-8"?>
<sequence name="get-specific-policy-sapi-sequence" trace="disable" xmlns="http://ws.apache.org/ns/synapse">
    <propertyGroup description="apiProperty">
        <property name="CorrelationID" expression="get-property('correlation_id')"/>
        <property name="LatencyMs" scope="default" type="STRING" value="0"/>
        <property name="StartTime" expression="get-property('SYSTEM_TIME')"/>
        <property name="policyNumber" expression="get-property('uri.var.policyId')"/>
        <property name="mongoQuery" type="STRING" expression="fn:concat('{&quot;policyNumber&quot;:&quot;', $ctx:policyNumber, '&quot;}')"/>
    </propertyGroup>
    <call-template target="Common-Log-Template-V1">
        <with-param name="service" value="policy-api"/>
        <with-param name="sequence" value="get-specific-policy-sapi-sequence"/>
        <with-param name="level" value="INFO"/>
        <with-param name="message" value="Started get-specific-policy-sapi-sequence"/>
        <with-param name="status" value="START"/>
    </call-template>
    <mongodb.findOne configKey="MongoDB-Connection-Policy-API">
        <collection>policies</collection>
        <query>{$ctx:mongoQuery}</query>
        <projection></projection>
        <collation></collation>
        <responseVariable>mongodb_findOne_1</responseVariable>
        <overwriteBody>true</overwriteBody>
    </mongodb.findOne>  
    <property name="isFound" expression="json-eval($.found)" scope="default"/>
    <filter xpath="$ctx:isFound = 'true'">
        <then>
            <log category="INFO" logMessageID="true" logFullPayload="true">
                <message>Crossed is found filter+++++</message>
            </log>
            <property name="policyStatusCode" type="STRING" expression="json-eval($.data.policyStatusCode)"/>
            <filter xpath="$ctx:policyStatusCode = 'ACTIVE'">
                <then>
                    <log category="INFO" logMessageID="true" logFullPayload="true">
                        <message>Crossed policyStatusCode filter+++++</message>
                    </log>                
                    <!-- Check Lapse Logic -->
                    <script language="js"><![CDATA[
                        var payload = mc.getPayloadJSON();
                        var policy = payload.data;

                        var today = new Date();
                        var termEnd = new Date(policy.termEndDate);

                        var isLapsed = false;
                        if (policy.termEndDate != null && today > termEnd) {
                            isLapsed = true;
                        }

                        mc.setProperty("isLapsed", isLapsed);
                    ]]></script>
                    <log level="custom">
                        <property name="IsLapsed" expression="$ctx:isLapsed"/>
                    </log>
                    <!-- ====================================================== -->
                    <!-- 4️⃣ If Lapsed → Update DB -->
                    <!-- ====================================================== -->
                    <property name="IsLapsed" type="STRING" expression="$ctx:isLapsed"/>
                    <filter xpath="$ctx:IsLapsed = 'true'">
                        <then>
                            <log category="INFO" logMessageID="true" logFullPayload="true">
                                <message>Crossed isLapsed filter+++++</message>
                            </log>
                            <log level="custom">
                                <property name="INFO" value="Policy has lapsed. Updating DB..."/>
                            </log>

                            <payloadFactory media-type="json">
                                <format>
                                    {
                                    "$set": {
                                    "policyStatusCode": "LAPSED"
                                    }
                                    }
                                </format>
                                <args>
                                </args>
                            </payloadFactory>
                            <property name="updatePayload" expression="json-eval($)" scope="default" type="STRING"/>
                            <mongodb.updateOne configKey="MongoDB-Connection-Policy-API">
                                <collection>policies</collection>
                                <query>{$ctx:mongoQuery}</query>
                                <update>{$ctx:updatePayload}</update>
                                <upsert>False</upsert>
                                <collation></collation>
                                <arrayFilters></arrayFilters>
                                <responseVariable>UpdatePolicyCollectionResult</responseVariable>
                                <overwriteBody>true</overwriteBody>
                            </mongodb.updateOne>                            
                            <mongodb.findOne configKey="MongoDB-Connection-Policy-API">
                                <collection>policies</collection>
                                <query>{$ctx:mongoQuery}</query>
                                <projection></projection>
                                <collation></collation>
                                <responseVariable>mongodb_findOne_1</responseVariable>
                                <overwriteBody>true</overwriteBody>
                            </mongodb.findOne>
                            <!-- Remove _id -->
                            <log category="INFO" logMessageID="true" logFullPayload="true">
                                <message>Before Script for Islapsed+++++</message>
                            </log>
                            <script language="js"><![CDATA[
                                var payload = mc.getPayloadJSON();
                                if (payload && payload.found && payload.data) {
                                
                                        delete payload.data._id;
                                
                                    mc.setPayloadJSON(payload.data);
                                } else {
                                    mc.setPayloadJSON([]);
                                }
                            ]]></script>                             
                        </then>
                        <!-- ================================================== -->
                        <!-- 5️⃣ If Not Lapsed -->
                        <!-- ================================================== -->
                        <else>
                            <log category="INFO" logMessageID="true" logFullPayload="true">
                                <message>Before Script for else condition Islapsed+++++</message>
                            </log>
 
                            <script language="js"><![CDATA[
                                var payload = mc.getPayloadJSON();
                                if (payload && payload.found && payload.data) {
                                
                                        delete payload.data._id;
                                
                                    mc.setPayloadJSON(payload.data);
                                } else {
                                    mc.setPayloadJSON([]);
                                }
                            ]]></script>                             
                        </else>
                    </filter>
                </then>
                <!-- ====================================================== -->
                <!-- 6️⃣ If Policy NOT ACTIVE -->
                <!-- ====================================================== -->
                <else>
                    <log category="INFO" logMessageID="true" logFullPayload="true">
                        <message>Before Script if policy not active+++++</message>
                    </log>                    
                    <script language="js"><![CDATA[
                        var payload = mc.getPayloadJSON();
                        if (payload && payload.found && payload.data) {
                           
                                delete payload.data._id;
                           
                            mc.setPayloadJSON(payload.data);
                        } else {
                            mc.setPayloadJSON([]);
                        }
                    ]]></script>                    
                </else>
            </filter>
        </then>
        <else>
            <propertyGroup description="error details">
                <property value="404" name="ERROR_CODE" scope="default" type="STRING"/>
                <property value="Not Found" name="ERROR_MESSAGE" scope="default" type="STRING"/>
                <property value="No details found for the provided policy number" name="ERROR_DETAIL" scope="default" type="STRING"/>
                <property name="HTTP_SC" scope="axis2" type="STRING" action="set" value="404"/>
            </propertyGroup>
            <call-template description="Error Log" target="Common-Log-Template-V1">
                <with-param name="service" value="policy-api"/>
                <with-param name="sequence" value="get-specific-policy-sapi-sequence"/>
                <with-param name="level" value="INFO"/>
                <with-param name="message" value="{$ctx:ERROR_MESSAGE}"/>
                <with-param name="status" value="ERROR"/>
            </call-template>
            <sequence key="policy-sapi-fault-sequence"/>
        </else>
    </filter>
    <property name="LatencyMs" expression="get-property('SYSTEM_TIME') - get-property('StartTime')"/>
    <call-template target="Common-Log-Template-V1">
        <with-param name="service" value="policy-api"/>
        <with-param name="sequence" value="get-specific-policy-sapi-sequence"/>
        <with-param name="level" value="INFO"/>
        <with-param name="message" value="Ended get-specific-policy-sapi-sequence"/>
        <with-param name="status" value="END"/>
    </call-template>
</sequence>