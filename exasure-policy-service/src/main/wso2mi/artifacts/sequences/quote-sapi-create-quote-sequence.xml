<?xml version="1.0" encoding="UTF-8"?>
<sequence name="quote-sapi-create-quote-sequence" xmlns="http://ws.apache.org/ns/synapse">
    <propertyGroup description="apiProperty">
        <property name="CorrelationID" expression="get-property('correlation_id')"/>
        <property name="LatencyMs" scope="default" type="STRING" value="0"/>
        <property name="StartTime" expression="get-property('SYSTEM_TIME')"/>
    </propertyGroup>
    <call-template target="Common-Log-Template-V1" description="start-log">
        <with-param name="service" value="quote-sapi"/>
        <with-param name="sequence" value="quote-sapi-create-quote-sequence"/>
        <with-param name="level" value="INFO"/>
        <with-param name="message" value="Started quote-sapi-create-quote-sequence"/>
        <with-param name="status" value="START"/>
    </call-template>
    <!-- Transform and enrich payload using script -->
    <!-- Generate PDF using custom class mediator -->
    <mongodb.insertOne configKey="WSO2-MongoDB-Connection">
        <collection>quotes</collection>
        <document>{json-eval($)}</document>
        <responseVariable>dbResult</responseVariable>
        <overwriteBody>false</overwriteBody>
    </mongodb.insertOne>
    <property name="LatencyMs" expression="get-property('SYSTEM_TIME') - get-property('StartTime')"/>
    <call-template target="Common-Log-Template-V1" description="end-log">
        <with-param name="service" value="quote-sapi"/>
        <with-param name="sequence" value="quote-sapi-create-quote-sequence"/>
        <with-param name="level" value="INFO"/>
        <with-param name="message" value="Ended quote-sapi-create-quote-sequence"/>
        <with-param name="status" value="END"/>
    </call-template>
    <respond/>
</sequence>