<?xml version="1.0" encoding="UTF-8"?>
<sequence name="policy-admin-papi-get-reInstatement-sequence" trace="disable" xmlns="http://ws.apache.org/ns/synapse">
    <call-template target="Common-Log-Template-V1" description="start-log">
        <with-param name="service" value="policy-admin-papi"/>
        <with-param name="sequence" value="policy-admin-papi-get-reInstatement-sequence"/>
        <with-param name="level" value="INFO"/>
        <with-param name="message" value="Initiating policy-admin-papi-get-reInstatement-sequence"/>
        <with-param name="status" value="START"/>
    </call-template>
    <property name="reInstatementId" expression="get-property('uri.var.reInstatementId')"/>
    <property name="HTTP_METHOD" scope="axis2" value="GET"/>
    <property name="REST_URL_POSTFIX" scope="axis2" expression="concat('/policies/reinstatement/', $ctx:reInstatementId)"/>
    <log level="full"/>
    <call>
        <endpoint key="reinstatement-sapi-restEndpoint"/>
    </call>
    <log level="full"/>
    <call-template target="Common-Log-Template-V1" description="end-log">
        <with-param name="service" value="policy-admin-papi"/>
        <with-param name="sequence" value="policy-admin-papi-get-reInstatement-sequence"/>
        <with-param name="level" value="INFO"/>
        <with-param name="message" value="Ending policy-admin-papi-get-reInstatement-sequence"/>
        <with-param name="status" value="END"/>
    </call-template>
    <respond/>
</sequence>