<?xml version="1.0" encoding="UTF-8"?>
<sequence name="quote-sapi-patch-discardQuote-sequence" onError="quote-sapi-common-fault-sequence" trace="disable" xmlns="http://ws.apache.org/ns/synapse">
    <propertyGroup description="apiProperty">
        <property name="CorrelationID" expression="get-property('correlation_id')"/>
        <property name="LatencyMs" scope="default" type="STRING" value="0"/>
        <property name="StartTime" expression="get-property('SYSTEM_TIME')"/>
        <property name="quoteId" expression="get-property('uri.var.quoteId')"/>
    </propertyGroup>
    <call-template target="Common-Log-Template-V1" description="start-log">
        <with-param name="service" value="quote-api"/>
        <with-param name="sequence" value="quote-sapi-patch-discardQuote-sequence"/>
        <with-param name="level" value="INFO"/>
        <with-param name="message" value="{fn:concat('Initiating quote-sapi-patch-discardQuote-sequence for quoteId- ', $ctx:uri.var.quoteId)}"/>
        <with-param name="status" value="START"/>
    </call-template>
    <property name="updateQuery" expression="fn:concat('{&quot;quote.quoteId&quot;:&quot;', $ctx:quoteId, '&quot;}')"/>
    <payloadFactory description="update status" media-type="json" template-type="default">
        <format>{"$set":{"quote.status": "DISCARDED"}}</format>
    </payloadFactory>
    <property name="updatePayload" expression="json-eval($)" scope="default" type="STRING"/>
    <mongodb.updateOne configKey="WSO2-MongoDB-Connection">
        <collection>quotes</collection>
        <query>{$ctx:updateQuery}</query>
        <update>{$ctx:updatePayload}</update>
        <upsert>False</upsert>
        <collation></collation>
        <arrayFilters></arrayFilters>
        <responseVariable>discardQuoteQueryResult</responseVariable>
        <overwriteBody>true</overwriteBody>
    </mongodb.updateOne>
    <filter xpath="${payload.matchedCount &gt; 0}">
        <then>
            <filter xpath="${payload.modifiedCount &gt; 0}">
                <then>
                    <property name="updateQuery" expression="fn:concat('{&quot;quote.quoteId&quot;:&quot;', $ctx:quoteId, '&quot;}')"/>
                    <mongodb.findOne configKey="WSO2-MongoDB-Connection">
                        <collection>quotes</collection>
                        <query>{$ctx:updateQuery}</query>
                        <projection></projection>
                        <collation></collation>
                        <responseVariable>quoteDetailsResult</responseVariable>
                        <overwriteBody>true</overwriteBody>
                    </mongodb.findOne>
                    <filter source="json-eval($.found)" regex="true">
                        <then>
                            <!-- SUCCESS SCENARIO -->
                            <script language="js"><![CDATA[
var response = mc.getPayloadJSON();

// Ensure data object exists
if (response && response.data) {

    var dataObj = response.data;

    // Remove _id if present
    if (dataObj._id) {
        delete dataObj._id;
    }

    // Set cleaned object as final payload
    mc.setPayloadJSON(dataObj);
}
]]></script>
                        </then>
                        <else>
                            <!-- ERROR SCENARIO -->
                            <property name="messageType" value="application/json" scope="axis2"/>
                            <property name="HTTP_SC" value="404" scope="axis2"/>
                            <payloadFactory media-type="json">
                                <format>
                                    {
                                    "errorCode": "404",
                                    "errorMessage": "Data not found",
                                    "errorDetails": "The data requested is not found in database.",
                                    "transactionId": "$1",
                                    "timeStamp": "$2"
                                    }
                                </format>
                                <args>
                                    <arg expression="get-property('correlation_id')"/>
                                    <arg expression="get-property('SYSTEM_DATE')"/>
                                </args>
                            </payloadFactory>
                        </else>
                    </filter>
                </then>
                <else>
                    <payloadFactory media-type="json">
                        <format>
                            {
                            "errorMessage": "Qoute already in Discarded status"
                            }
                        </format>
                    </payloadFactory>
                </else>
            </filter>
        </then>
        <else>
            <payloadFactory media-type="json">
                <format>
                    {
                    "errorCode": "404",
                    "errorMessage": "Data not found",
                    "errorDetails": "The data requested is not found in database.",
                    "transactionId": "$1",
                    "timeStamp": "$2"
                    }
                </format>
                <args>
                    <arg expression="get-property('correlation_id')"/>
                    <arg expression="get-property('SYSTEM_DATE')"/>
                </args>
            </payloadFactory>
        </else>
    </filter>
    <call-template target="Common-Log-Template-V1" description="end-log">
        <with-param name="service" value="quote-api"/>
        <with-param name="sequence" value="quote-sapi-patch-discardQuote-sequence"/>
        <with-param name="level" value="INFO"/>
        <with-param name="message" value="{fn:concat('Ending quote-sapi-patch-discardQuote-sequence for quoteId- ', $ctx:uri.var.quoteId)}"/>
        <with-param name="status" value="END"/>
    </call-template>
    <respond description="respond to client"/>
</sequence>