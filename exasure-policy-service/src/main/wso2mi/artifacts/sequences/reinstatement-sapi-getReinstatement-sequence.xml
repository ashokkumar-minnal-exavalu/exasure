<?xml version="1.0" encoding="UTF-8"?>
<sequence name="reinstatement-sapi-getReinstatement-sequence" trace="disable" xmlns="http://ws.apache.org/ns/synapse">
    <call-template target="Common-Log-Template-V1" description="start-log">
        <with-param name="service" value="reinstatement-sapi"/>
        <with-param name="sequence" value="reinstatement-sapi-getReinstatement-sequence"/>
        <with-param name="level" value="INFO"/>
        <with-param name="message" value="{fn:concat('Initiating reinstatement-sapi-getReinstatement-sequence for reinstatementId- ', $ctx:uri.var.reinstatementId)}"/>
        <with-param name="status" value="START"/>
    </call-template>
    <propertyGroup description="apiProperty">
        <property name="CorrelationID" expression="get-property('correlation_id')"/>
        <property name="LatencyMs" scope="default" type="STRING" value="0"/>
        <property name="StartTime" expression="get-property('SYSTEM_TIME')"/>
        <property name="reinstatementId" expression="get-property('uri.var.reinstatementId')"/>
    </propertyGroup>
    
    <property name="updateQuery" expression="fn:concat('{&quot;reinstatementId&quot;:&quot;', $ctx:reinstatementId, '&quot;}')"/>
    <mongodb.findOne configKey="WSO2-Accelerator-DB">
        <collection>Reinstatement</collection>
        <query>{$ctx:updateQuery}</query>
        <projection></projection>
        <collation></collation>
        <responseVariable>reinstatmentDetailsResult</responseVariable>
        <overwriteBody>true</overwriteBody>
    </mongodb.findOne>
    <filter source="json-eval($.found)" regex="true">
        <then>
            <!-- SUCCESS SCENARIO -->
            <script language="js"><![CDATA[
var response = mc.getPayloadJSON();

// Ensure data object exists
if (response && response.data) {

    var dataObj = response.data;

    // Remove _id if present
    if (dataObj._id) {
        delete dataObj._id;
    }

    // Set cleaned object as final payload
    mc.setPayloadJSON(dataObj);
}
]]></script>
        </then>
        <else>
            <!-- ERROR SCENARIO -->
            <property name="messageType" value="application/json" scope="axis2"/>
            <property name="HTTP_SC" value="404" scope="axis2"/>
            <payloadFactory media-type="json">
                <format>
                    {
                    "errorCode": "404",
                    "errorMessage": "Data not found",
                    "errorDetails": "The data requested is not found in database.",
                    "transactionId": "$1",
                    "timeStamp": "$2"
                    }
                </format>
                <args>
                    <arg expression="get-property('correlation_id')"/>
                    <arg expression="get-property('SYSTEM_DATE')"/>
                </args>
            </payloadFactory>
        </else>
    </filter>
    <call-template target="Common-Log-Template-V1" description="end-log">
        <with-param name="service" value="reinstatement-sapi"/>
        <with-param name="sequence" value="reinstatement-sapi-getReinstatement-sequence"/>
        <with-param name="level" value="INFO"/>
        <with-param name="message" value="{fn:concat('Ending reinstatement-sapi-getReinstatement-sequence for reinstatementId- ', $ctx:uri.var.reinstatementId)}"/>
        <with-param name="status" value="END"/>
    </call-template>
    <respond description="respond to client"/>
</sequence>