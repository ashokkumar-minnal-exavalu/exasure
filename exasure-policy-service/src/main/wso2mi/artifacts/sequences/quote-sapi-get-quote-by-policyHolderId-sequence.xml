<?xml version="1.0" encoding="UTF-8"?>
<sequence name="quote-sapi-get-quote-by-policyHolderId-sequence" xmlns="http://ws.apache.org/ns/synapse">
    <call-template target="Common-Log-Template-V1" description="start-log">
        <with-param name="service" value="quote-api"/>
        <with-param name="sequence" value="Get-quote-by-policyHolderId-sapi"/>
        <with-param name="level" value="INFO"/>
        <with-param name="message" value="{fn:concat('Initiating Get-quote-by-policyHolderId-sapi for for policyHolderId- ', $ctx:uri.var.policyHolderId) }"/>
        <with-param name="status" value="START"/>
    </call-template>
    <property name="policyHolderId" expression="get-property('uri.var.policyHolderId')"/>
    <property name="mongoQuery" type="STRING" expression="fn:concat('{&quot;parties.partyIdentifier&quot;:&quot;', $ctx:policyHolderId, '&quot;}')"/>
    <log level="custom">
        <property name="STEP" value="Before MongoDB Query"/>
        <property name="Query" expression="$ctx:mongoQuery"/>
    </log>
    <mongodb.find configKey="WSO2-MongoDB-Connection">
        <collection>quotes</collection>
        <query>{$ctx:mongoQuery}</query>
        <projection></projection>
        <collation></collation>
        <limit>5000</limit>
        <sort></sort>
        <responseVariable>mongodb_result</responseVariable>
        <overwriteBody>true</overwriteBody>
    </mongodb.find>
    <log level="full">
        <property name="STEP" value="After MongoDB Result"/>
        <property name="Data" expression="json-eval($.data)"/>
    </log>
    <property name="messageType" value="application/json" scope="axis2"/>
    <filter source="json-eval($.found)" regex="true">
        <then>
            <!-- SUCCESS SCENARIO -->
            <script language="js"><![CDATA[
var payload = mc.getPayloadJSON();

if (payload && payload.data && Array.isArray(payload.data)) {

    var cleanedArray = payload.data.map(function(item) {

        if (item && item._id) {
            delete item._id;
        }

        return item;
    });

    mc.setPayloadJSON(cleanedArray);

} else {
    mc.setPayloadJSON([]);
}
]]></script>
        </then>
        <else>
            <!-- ERROR SCENARIO -->
            <property name="messageType" value="application/json" scope="axis2"/>
            <property name="HTTP_SC" value="404" scope="axis2"/>
            <payloadFactory media-type="json">
                <format>
                    {
                    "errorCode": "404",
                    "errorMessage": "Data not found",
                    "errorDetails": "The data requested is not found in database.",
                    "transactionId": "$1",
                    "timeStamp": "$2"
                    }
                </format>
                <args>
                    <arg expression="get-property('correlation_id')"/>
                    <arg expression="get-property('SYSTEM_DATE')"/>
                </args>
            </payloadFactory>
        </else>
    </filter>
    <call-template target="Common-Log-Template-V1" description="end-log">
        <with-param name="service" value="quote-api"/>
        <with-param name="sequence" value="Get-quote-by-policyHolderId-sapi"/>
        <with-param name="level" value="INFO"/>
        <with-param name="message" value="{fn:concat('Ending Get-quote-by-policyHolderId-sapi for policyHolderId- ', $ctx:uri.var.policyHolderId) }"/>
        <with-param name="status" value="END"/>
    </call-template>
    <respond/>
</sequence>
