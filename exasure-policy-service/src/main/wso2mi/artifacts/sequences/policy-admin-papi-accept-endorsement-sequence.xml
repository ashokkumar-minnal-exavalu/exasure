<?xml version="1.0" encoding="UTF-8"?>
<sequence name="policy-admin-papi-accept-endorsement-sequence"
          trace="disable"
          xmlns="http://ws.apache.org/ns/synapse">

    <property name="messageType" value="application/json" scope="axis2"/>
    <property name="ContentType" value="application/json" scope="axis2"/>
    <property name="Accept" scope="transport" value="application/json"/>

    <propertyGroup description="apiProperty">
        <property name="CorrelationID" expression="get-property('correlation_id')"/>
        <property name="StartTime" expression="get-property('SYSTEM_TIME')"/>
        <property name="LatencyMs" scope="default" type="STRING" value="0"/>
        <property name="endorsementId" expression="get-property('uri.var.endorsementId')" scope="default" type="STRING"/>
    </propertyGroup>

    <call-template target="Common-Log-Template-V1" description="start-log">
        <with-param name="service" value="policy-admin-papi"/>
        <with-param name="sequence" value="policy-admin-papi-accept-endorsement-sequence"/>
        <with-param name="level" value="INFO"/>
        <with-param name="message" value="{fn:concat('Initiating accept endorsement (PAPI) for endorsementId - ', $ctx:endorsementId)}"/>
        <with-param name="status" value="START"/>
    </call-template>

    <enrich>
        <source type="body" clone="true"/>
        <target type="property" property="REQ_BODY_BACKUP"/>
    </enrich>

    <!-- Ensure valid JSON body is sent to SAPI -->
    <script language="js"><![CDATA[
        var isEmpty = false;
        try {
            var req = mc.getPayloadJSON();
            if (req === null || (typeof req === "object" && Object.keys(req).length === 0)) {
                isEmpty = true;
            }
        } catch(e) {
            isEmpty = true;
        }
        if (isEmpty) {
            mc.setPayloadJSON({});
        }
    ]]></script>

    <call-template target="Common-Log-Template-V1" description="processing-log">
        <with-param name="service" value="policy-admin-papi"/>
        <with-param name="sequence" value="policy-admin-papi-accept-endorsement-sequence"/>
        <with-param name="level" value="INFO"/>
        <with-param name="message" value="{fn:concat('Calling endorsement-sapi accept endpoint for endorsementId - ', $ctx:endorsementId)}"/>
        <with-param name="status" value="PROCESSING"/>
    </call-template>

    <!-- Call SAPI -->
    <property name="HTTP_METHOD" scope="axis2" value="PATCH"/>
    <property name="REST_URL_POSTFIX"
              scope="axis2"
              expression="fn:concat('/endorsements/', $ctx:endorsementId, '/accept')"/>

    <call>
        <endpoint key="endorsement-sapi-restEndpoint"/>
    </call>

    <property name="SAPI_HTTP_SC" expression="$axis2:HTTP_SC" scope="default" type="STRING"/>

    <log level="custom">
        <property name="CHECKPOINT" value="AFTER_SAPI_CALL"/>
        <property name="SAPI_HTTP_SC" expression="$ctx:SAPI_HTTP_SC"/>
        <property name="SAPI_PAYLOAD" expression="json-eval($.)"/>
    </log>

    <!-- Transform only success responses -->
    <filter xpath="$ctx:SAPI_HTTP_SC = '200'">
        <then>

            <script language="js"><![CDATA[
                function safe(o) {
                    return (o && typeof o === "object") ? o : {};
                }

                var doc = safe(mc.getPayloadJSON());
                var status = String(doc.endorsementStatusCode || "");
                var processingStatus = String(doc.processingStatus || "");
                var pv = safe(doc.policyVersion);
                var pe = safe(doc.policyEvent);

                // Already accepted / issued case from SAPI
                if (processingStatus === "NO_ACTION_REQUIRED") {
                    mc.setPayloadJSON({
                        endorsementStatusCode: status,
                        processingStatus: "NO_ACTION_REQUIRED",
                        message: doc.message || "Endorsement has already been accepted, no further acceptance is required."
                    });
                }
                // VALIDATED case: SAPI returns raw accepted endorsement doc, PAPI transforms it
                else if (status === "ACCEPTED") {
                    mc.setPayloadJSON({
                        policyNumber: doc.policyNumber,
                        policyVersionIdentifier: pv.policyVersionIdentifier,
                        versionNumber: pv.versionNumber,
                        transactionTypeCode: pv.transactionTypeCode,
                        versionEffectiveDate: pv.versionEffectiveDate,
                        assessmentStatusCode: "PASSED",
                        endorsementStatusCode: status,
                        policyEvent: {
                            eventTypeCode: pe.eventTypeCode,
                            eventDate: pe.eventDate
                        },
                        message: "Endorsement accepted successfully"
                    });
                }
                // Defensive fallback
                else {
                    mc.setPayloadJSON({
                        errorCode: "ENDORSEMENT_INVALID_STATUS",
                        message: "Endorsement cannot be accepted when the endorsementStatusCode is not VALIDATED."
                    });
                    mc.setProperty("HTTP_SC", "400");
                }
            ]]></script>

            <filter xpath="$ctx:HTTP_SC = '400'">
                <then>
                    <property name="HTTP_SC" value="400" scope="axis2"/>
                </then>
                <else>
                    <property name="HTTP_SC" value="200" scope="axis2"/>
                </else>
            </filter>

            <property name="LatencyMs" expression="get-property('SYSTEM_TIME') - get-property('StartTime')"/>

            <call-template target="Common-Log-Template-V1" description="end-log">
                <with-param name="service" value="policy-admin-papi"/>
                <with-param name="sequence" value="policy-admin-papi-accept-endorsement-sequence"/>
                <with-param name="level" value="INFO"/>
                <with-param name="message" value="{fn:concat('Ending accept endorsement (PAPI) for endorsementId - ', $ctx:endorsementId)}"/>
                <with-param name="status" value="END"/>
            </call-template>

            <respond/>
        </then>
        <else/>
    </filter>

    <!-- Pass through non-200 errors from SAPI -->
    <property name="HTTP_SC" expression="$ctx:SAPI_HTTP_SC" scope="axis2"/>

    <call-template target="Common-Log-Template-V1" description="error-log">
        <with-param name="service" value="policy-admin-papi"/>
        <with-param name="sequence" value="policy-admin-papi-accept-endorsement-sequence"/>
        <with-param name="level" value="INFO"/>
        <with-param name="message" value="{fn:concat('SAPI returned error for endorsementId - ', $ctx:endorsementId, ', HTTP_SC=', $ctx:SAPI_HTTP_SC)}"/>
        <with-param name="status" value="ERROR"/>
    </call-template>

    <respond/>
</sequence>