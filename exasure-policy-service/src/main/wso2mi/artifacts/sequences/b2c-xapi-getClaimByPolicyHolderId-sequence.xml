<?xml version="1.0" encoding="UTF-8"?>
<sequence name="b2c-xapi-getClaimByPolicyHolderId-sequence" trace="disable" xmlns="http://ws.apache.org/ns/synapse">
	<filter xpath="${exists(params.pathParams.policyHolderId)}">
		<then>
			<call-template target="Common-Log-Template-V1" description="start_log">
				<with-param name="service" value="b2c-xapi"/>
				<with-param name="sequence" value="b2c-xapi-getClaimByPolicyHolderId-sequence"/>
				<with-param name="level" value="INFO"/>
				<with-param name="message" value="{${'Initiating b2c-xapi-getClaimByPolicyHolderId-sequence for PolicyHolderId: ' + params.pathParams.policyHolderId}}"/>
				<with-param name="status" value="START"/>
			</call-template>
			<propertyGroup description="post_quote">
				<property name="HTTP_METHOD" scope="axis2" type="STRING" value="GET"/>
				<property name="REST_URL_POSTFIX" scope="axis2" type="STRING" expression="fn:concat('/claim/policyHolder/', get-property('uri.var.policyHolderId'))"/>
			</propertyGroup>
			<call>
				<endpoint key="claim-papi-restEndpoint"/>
			</call>
			<call-template target="Common-Log-Template-V1">
				<with-param name="service" value="b2c-xapi"/>
				<with-param name="sequence" value="b2c-xapi-getClaimByPolicyHolderId-sequence"/>
				<with-param name="level" value="INFO"/>
				<with-param name="message" value="{${'Ending b2c-xapi-getClaimByPolicyHolderId-sequence for PolicyHolderId: ' + params.pathParams.policyHolderId}}"/>
				<with-param name="status" value="END"/>
			</call-template>
			<respond/>
		</then>
		<else>
			<variable name="ERROR_CODE" type="STRING" value="VALIDATION_ERROR"/>
			<variable name="ERROR_MESSAGE" type="STRING" value="PolicyHolderId parameter is missing"/>
			<variable name="ERROR_DETAIL" value="The PolicyHolderId path parameter is required" type="STRING"/>
			<variable name="HTTP_SC" value="400" type="STRING"/>
			<sequence key="b2c-xapi-common-fault-sequence"/>
		</else>
	</filter>
</sequence>
