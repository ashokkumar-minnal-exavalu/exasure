<?xml version="1.0" encoding="UTF-8"?>
<sequence name="policy-admin-papi-get-vehicles-by-quoteId-sequence" xmlns="http://ws.apache.org/ns/synapse">
    <call-template target="Common-Log-Template-V1" description="end-log">
        <with-param name="service" value="policy-admin-papi"/>
        <with-param name="sequence" value="policy-admin-papi-get-vehicles-by-quoteId-sequence"/>
        <with-param name="level" value="INFO"/>
        <with-param name="message" value="{fn:concat('Initiating policy-admin-papi-get-vehicles-by-quoteId-sequence for quoteId- ', $ctx:uri.var.quoteId)}"/>
        <with-param name="status" value="START"/>
    </call-template>
    <propertyGroup>
        <property name="HTTP_METHOD" scope="axis2" value="GET"/>
        <property name="quoteId" expression="get-property('uri.var.quoteId')"/>
        <property name="REST_URL_POSTFIX" scope="axis2" expression="concat('/fetch-vehicles/', $ctx:quoteId,)"/>
    </propertyGroup>
    <call>
        <endpoint key="vehicle-management-sapi-restEndpoint"/>
    </call>
    <script language="js"><![CDATA[
    var payload = mc.getPayloadJSON();

    var response = {
        insurableObjects: payload.data.map(function(item) {

            delete item._id;

            return {
                vehicle: item
            };
        })
    };

    mc.setPayloadJSON(response);
]]></script>
    <call-template target="Common-Log-Template-V1" description="start-log">
        <with-param name="service" value="policy-admin-papi"/>
        <with-param name="sequence" value="policy-admin-papi-get-vehicles-by-quoteId-sequence"/>
        <with-param name="level" value="INFO"/>
        <with-param name="message" value="{fn:concat('Ending policy-admin-papi-get-vehicles-by-quoteId-sequence for quoteId- ', $ctx:uri.var.quoteId)}"/>
        <with-param name="status" value="END"/>
    </call-template>
</sequence>