<?xml version="1.0" encoding="UTF-8"?>
<sequence name="post-user-signup-papi-sequence" trace="disable" xmlns="http://ws.apache.org/ns/synapse">
    <propertyGroup description="apiProperty">
        <property name="CorrelationID" expression="get-property('correlation_id')"/>
        <property name="LatencyMs" scope="default" type="STRING" value="0"/>
        <property name="StartTime" expression="get-property('SYSTEM_TIME')"/>
        <property name="Input-Payload" scope="default" type="STRING" expression="json-eval($)"/>
    </propertyGroup>    
    <call-template target="Common-Log-Template-V1">
        <with-param name="service" value="user-api"/>
        <with-param name="sequence" value="post-user-signup-papi-sequence"/>
        <with-param name="level" value="INFO"/>
        <with-param name="message" value="Started post-user-signup-papi-sequence"/>
        <with-param name="status" value="START"/>
    </call-template>
    <payloadFactory media-type="json">
        <format>
            {
            "email": "$1",
            "password": "$2",
            "firstName": "$3",
            "lastName": "$4",
            "role": "user"
            }
        </format>
        <args>
            <arg evaluator="json" expression="$.email"/>
            <arg evaluator="json" expression="$.password"/>
            <arg evaluator="json" expression="$.firstName"/>
            <arg evaluator="json" expression="$.lastName"/>
        </args>
    </payloadFactory>    
    <propertyGroup description="inputProperty">
        <property name="HTTP_METHOD" scope="axis2" type="STRING" value="POST"/>
        <property name="REST_URL_POSTFIX" scope="axis2" type="STRING" value="/signup"/>
    </propertyGroup>
    <call>
        <endpoint key="user-sapi-restEndpoint"/>
    </call>    
    <property name="insertedCount" expression="json-eval($.insertedCount)" scope="default"/>
    <filter xpath="$ctx:insertedCount = 1">
        <then>
            <payloadFactory media-type="json">
                <format>
                    {
                    "isSuccessfull": true,
                    "userId": "$1",
                    "firstName": "$2",
                    "lastName": "$3",
                    "message": "User registered successfully"
                    }
                </format>
                <args>
                    <arg evaluator="json" expression="$ctx:Input-Payload.email"/>
                    <arg evaluator="json" expression="$ctx:Input-Payload.firstName"/>
                    <arg evaluator="json" expression="$ctx:Input-Payload.lastName"/>
                </args>
            </payloadFactory>
        </then>
        <else>
            <propertyGroup description="error details">
                <property expression="json-eval($.errors[0].errorCode)" name="ERROR_CODE" scope="default" type="STRING"/>
                <property expression="json-eval($.errors[0].errorMessage)" name="ERROR_MESSAGE" scope="default" type="STRING"/>
                <property expression="json-eval($.errors[0].errorDescription)" name="ERROR_DETAIL" scope="default" type="STRING"/>
            </propertyGroup>
            <call-template description="Error Log" target="Common-Log-Template-V1">
                <with-param name="service" value="user-api"/>
                <with-param name="sequence" value="post-user-signup-papi-sequence"/>
                <with-param name="level" value="INFO"/>
                <with-param name="message" value="{$ctx:ERROR_MESSAGE}"/> 
                <with-param name="status" value="ERROR"/>
            </call-template>                    
            <sequence key="user-papi-fault-sequence"/>            
        </else>
    </filter>
    <property name="LatencyMs" expression="get-property('SYSTEM_TIME') - get-property('StartTime')"/>    
    <call-template target="Common-Log-Template-V1">
        <with-param name="service" value="user-api"/>
        <with-param name="sequence" value="post-user-signup-papi-sequence"/>
        <with-param name="level" value="INFO"/>
        <with-param name="message" value="Ended post-user-signup-papi-sequence"/>
        <with-param name="status" value="END"/>
    </call-template>
</sequence>