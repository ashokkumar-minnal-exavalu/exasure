<?xml version="1.0" encoding="UTF-8"?>
<api context="/billing-payment-papi/api" name="billing-payment-papi-api" xmlns="http://ws.apache.org/ns/synapse">
    <resource methods="POST" uri-template="/refund">
        <inSequence>
            <sequence key="refund-billing-payment-papi-sequence"/>
            <respond/>
        </inSequence>
        <faultSequence/>
    </resource>

    <resource methods="GET" uri-template="/billing-payment/agents/{quoteId}/agent-statements/quote">
        <inSequence>
            <sequence key="billing-payment-papi-retrieve-agentstatement-sequence"/>
            <respond/>
        </inSequence>
        <faultSequence/>
    </resource>

    <!-- ✅ Your endpoint -->
    <resource methods="GET" uri-template="/agent">
        <inSequence>
            <sequence key="billing-payment-papi-agent-payout-sequence"/>
            <respond/>
        </inSequence>
        <faultSequence/>
    </resource>

    <!-- ✅ Remote endpoint -->
    <resource methods="GET" uri-template="/billing-payment/agents/{agentId}/statements">
        <inSequence>
            <sequence key="get-agent-statements-billing-payment-papi-sequence"/>
            <respond/>
        </inSequence>
        <faultSequence/>
    </resource>
    <resource methods="GET" uri-template="/mail">
        <inSequence>
            <respond/>
        </inSequence>
        <faultSequence>
        </faultSequence>
    </resource>
    <resource methods="POST" uri-template="/billing-payment/billing">
        <inSequence>
            <sequence key="billing-payment-papi-create-billing-sequence"/>
            <respond/>
        </inSequence>
        <faultSequence>
        </faultSequence>
    </resource>
    <resource methods="GET" uri-template="/billing-payment/invoices/{invoiceId}">
        <inSequence>
            <sequence key="billing-payment-papi-retrive-invoices-by-invoiceId-sequence"/>
            <respond/>
        </inSequence>
        <faultSequence>
            <sequence key="billing-payment-papi-fault-sequence"/>
        </faultSequence>
    </resource>
    <resource methods="GET" uri-template="/billing-payment/invoices/fetch-all/{quoteId}">
        <inSequence>
            <sequence key="billing-payment-papi-retrive-invoices-by-quoteId-sequence"/>
            <respond/>
        </inSequence>
        <faultSequence>
            <sequence key="billing-payment-papi-fault-sequence"/>
        </faultSequence>
    </resource>
</api>