<?xml version="1.0" encoding="UTF-8"?>
<api context="/refund-sapi/api" name="refund-sapi-api" xmlns="http://ws.apache.org/ns/synapse">
    <resource methods="GET" uri-template="/refunds/retrieve/cancelPolicyDetails">
        <inSequence>
            <sequence key="get-all-cancelled-policies-refund-sapi-sequence"/>
            <respond/>
        </inSequence>
        <faultSequence>
        </faultSequence>
    </resource>
    <resource methods="POST" uri-template="/refunds/create">
        <inSequence>
            <sequence key="create-refund-sapi-sequence"/>
            <respond/>
        </inSequence>
        <faultSequence>
        </faultSequence>
    </resource>
    <resource methods="POST" uri-template="/refunds/store-refund">
        <inSequence>
            <sequence key="store-refund-sapi-sequence"/>
            <respond/>
        </inSequence>
        <faultSequence>
        </faultSequence>
    </resource>  
    <resource methods="GET" uri-template="/refunds/retrieve/{refundId}">
        <inSequence>
            <sequence key="fetch-refund-by-refundId-refund-sapi-sequence"/>
            <respond/>
        </inSequence>
        <faultSequence>
        </faultSequence>
    </resource>          
</api>