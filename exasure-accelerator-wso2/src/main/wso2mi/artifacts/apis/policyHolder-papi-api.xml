<?xml version="1.0" encoding="UTF-8"?>
<api context="/policyHolder-papi" name="policyHolder-papi-api" xmlns="http://ws.apache.org/ns/synapse">
    <resource methods="GET" uri-template="/api/{policyHolderId}">
        <inSequence>
            <sequence key="get-specific-policyHolder-papi-sequence"/>
            <respond/>
        </inSequence>
        <faultSequence>
        </faultSequence>
    </resource>
    <resource methods="POST" uri-template="/api/policyHolder">
        <inSequence>
            <sequence key="post-specific-policyHolder-papi-sequence" description="create policy Holder"/>
            <respond/>
        </inSequence>
        <faultSequence>
        </faultSequence>
    </resource>
    <resource methods="PATCH" uri-template="/api/{policyHolderId}">
        <inSequence>
            <sequence key="patch-specific-policyHolder-papi-sequence"/>
            <respond/>
        </inSequence>
        <faultSequence>
        </faultSequence>
    </resource>
    <resource methods="GET" uri-template="/api/policyholder/{policyHolderId}/policies">
        <inSequence>
            <sequence key="get-policies-against-policyHolder-papi-sequence"/>
            <respond/>
        </inSequence>
        <faultSequence>
        </faultSequence>
    </resource>
    <resource methods="GET" uri-template="/api/all/policyHolder">
        <inSequence>
            <sequence key="get-all-policyHolder-papi-sequence"/>
            <respond/>
        </inSequence>
        <faultSequence>
        </faultSequence>
    </resource>     
</api>