<?xml version="1.0" encoding="UTF-8"?>
<api context="/endorsement-sapi" name="endorsement-sapi" xmlns="http://ws.apache.org/ns/synapse">
    <resource methods="POST" uri-template="/policies/{policyId}/endorsements">
        <inSequence>
            <sequence key="endorsement-sapi-create-endorsement-sequence"/>
        </inSequence>
        <faultSequence>
        </faultSequence>
    </resource>
    <resource methods="GET" uri-template="/api/policies/{policyId}/endorsements">
        <inSequence>
            <sequence key="endorsement-sapi-get-all-endorsements-sequence"/>
            <respond/>
        </inSequence>
        <faultSequence>
        </faultSequence>
    </resource>
    <resource methods="POST" uri-template="/api/endorsements/{endorsementId}/validate">
        <inSequence>
            <sequence key="endorsement-sapi-validate-endorsement-sequence"/>
            <respond/>
        </inSequence>
        <faultSequence>
        </faultSequence>
    </resource>
    <resource methods="GET" uri-template="/api/endorsements/{endorsementId}">
        <inSequence>
            <sequence key="endorsement-sapi-get-endorsement-sequence"/>
            <respond/>
        </inSequence>
        <faultSequence>
        </faultSequence>
    </resource>
     <resource methods="PATCH" uri-template="/endorsements/{endorsementId}/accept">
        <inSequence>
            <sequence key="endorsement-sapi-accept-endorsement-sequence"/>
        </inSequence>
        <faultSequence>
        </faultSequence>
    </resource>
    <resource methods="PATCH" uri-template="/api/endorsements/{endorsementId}/issue">
        <inSequence>
            <sequence key="endorsement-sapi-issue-endorsement-sequence"/>
            <respond/>
        </inSequence>
        <faultSequence>
        </faultSequence>
    </resource>
    <resource methods="PATCH" uri-template="/endorsements/{endorsementId}/discard">
        <inSequence>
            <sequence key="endorsement-sapi-discard-endorsement-sequence"/>
            <respond/>
        </inSequence>
        <faultSequence>
        </faultSequence>
    </resource>
</api>