<?xml version="1.0" encoding="UTF-8"?>
<api context="/payable-sapi" name="payable-sapi-api" xmlns="http://ws.apache.org/ns/synapse">
    <resource methods="POST" uri-template="/payables">
        <inSequence>
            <sequence key="post-payable-sapi-sequence"/>
            <respond/>
        </inSequence>
        <faultSequence>
        </faultSequence>
    </resource>
    <resource methods="GET" uri-template="/payables/{claimId}">
        <inSequence>
            <sequence key="get-payable-sapi-sequence"/>
            <respond/>
        </inSequence>
        <faultSequence>
        </faultSequence>
    </resource>
    <resource methods="PATCH" uri-template="/payables/{claimId}">
        <inSequence>
            <sequence key="patch-payable-sapi-sequence"/>
            <respond/>
        </inSequence>
        <faultSequence>
        </faultSequence>
    </resource>        
</api>