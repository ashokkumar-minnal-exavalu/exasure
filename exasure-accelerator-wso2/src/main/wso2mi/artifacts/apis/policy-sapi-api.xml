<?xml version="1.0" encoding="UTF-8"?>
<api context="/policy-sapi" name="policy-sapi-api" xmlns="http://ws.apache.org/ns/synapse">
    <resource methods="GET" uri-template="/api/{policyId}">
        <inSequence>
            <sequence key="get-specific-policy-sapi-sequence"/>
            <respond/>
        </inSequence>
        <faultSequence>
        </faultSequence>
    </resource>
    <resource methods="POST" uri-template="/api/policy">
        <inSequence>
            <sequence key="post-specific-policy-sapi-sequence"/>
            <respond/>
        </inSequence>
        <faultSequence>
        </faultSequence>
    </resource>
    <resource methods="PATCH" uri-template="/api/policy/{policyNumber}/issuance">
        <inSequence>
            <sequence key="patch-issue-specific-policy-sapi-sequence"/>
            <respond/>
        </inSequence>
        <faultSequence>
        </faultSequence>
    </resource>
    <resource methods="PATCH" uri-template="/api/policy/{policyNumber}/cancellation">
        <inSequence>
            <sequence key="patch-cancel-specific-policy-sapi-sequence"/>
            <respond/>
        </inSequence>
        <faultSequence>
        </faultSequence>
    </resource>
    <resource methods="GET" uri-template="/api/all/policy">
        <inSequence>
            <sequence key="get-all-policy-sapi-sequence"/>
            <respond/>
        </inSequence>
        <faultSequence>
        </faultSequence>
    </resource>
</api>