<?xml version="1.0" encoding="UTF-8"?>
<sequence name="get-treasurydata-by-treasuryAccountIdSequence" trace="disable" xmlns="http://ws.apache.org/ns/synapse">
<call-template target="Common-Log-Template-V1">
        <with-param name="service" value="finance-papi-api"/>
        <with-param name="sequence" value="get-treasurydata-by-treasuryAccountIdSequence"/>
        <with-param name="level" value="INFO"/>
        <with-param name="message" value="Started get-treasurydata-by-treasuryAccountIdSequence"/>
        <with-param name="status" value="START"/>
</call-template>

<propertyGroup description="inputProperties">
        <property name="HTTP_METHOD" scope="axis2" type="STRING" value="GET"/>
        <property name="REST_URL_POSTFIX" scope="axis2" type="STRING" expression="fn:concat('treasury/transactions/', $ctx:treasuryAccountId)"/>
    </propertyGroup>
	<call>
        <endpoint key="finance-papi-restEndpoint"/>
    </call>

<filter xpath="$axis2:HTTP_SC = 404">
<then>
    <property name="ERROR_CODE" value="404"/>
    <property name="ERROR_MESSAGE" value="No treasury record found for this treasuryAccountId"/>
    <property name="ERROR_DETAIL" value="TREASURY_DATA_NOT_FOUND"/>
    <sequence key="finance-papi-fault-sequence"/>
</then>
</filter>
<log level="full">
<property name="Payload" expression="json-eval($)"/>
</log>
<payloadFactory media-type="json">
<format>$1</format>
<args>
    <arg evaluator="json" expression="$"/>
</args>
</payloadFactory>
<call-template target="Common-Log-Template-V1">
    <with-param name="service" value="finance-papi-api"/>
    <with-param name="sequence" value="get-treasurydata-by-treasuryAccountIdSequence"/>
    <with-param name="level" value="INFO"/>
    <with-param name="message" value="Ended get-treasurydata-by-treasuryAccountIdSequence"/>
    <with-param name="status" value="END"/>
</call-template>
</sequence>