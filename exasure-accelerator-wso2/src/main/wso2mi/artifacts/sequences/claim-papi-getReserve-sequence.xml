<?xml version="1.0" encoding="UTF-8"?>
<sequence name="claim-papi-getReserve-sequence" trace="disable" xmlns="http://ws.apache.org/ns/synapse">
   <propertyGroup description="apiProperty">
        <property name="CorrelationID" expression="get-property('correlation_id')"/>
        <property name="LatencyMs" scope="default" type="STRING" value="0"/>
        <property name="StartTime" expression="get-property('SYSTEM_TIME')"/>
        <property name="claimId" expression="get-property('uri.var.claimId')"/>
    </propertyGroup>
    <call-template target="Common-Log-Template-V1">
        <with-param name="service" value="claim-papi"/>
        <with-param name="sequence" value="claim-papi-getReserve-sequence"/>
        <with-param name="level" value="INFO"/>
        <with-param name="message" value="Start claim-papi-getReserve-sequence"/>
        <with-param name="status" value="START"/>
    </call-template>
    <propertyGroup description="inputProperty">
        <property name="HTTP_METHOD" scope="axis2" type="STRING" value="GET"/>
        <property name="REST_URL_POSTFIX" scope="axis2" type="STRING" expression="fn:concat('/api/claim/', get-property('claimId'), '/reserves')"/>
    </propertyGroup>
    <call>
        <endpoint key="reserve-management-sapi-restEndpoint"/>
    </call>
    <property description="statusCode" expression="$axis2:HTTP_SC" name="statusCode" scope="default" type="STRING"/>
   <filter xpath="get-property('statusCode')='200'">
        <then>
<script language="js"><![CDATA[
var payload = mc.getPayloadJSON();
var data = payload.data || [];

// remove _id
for (var i = 0; i < data.length; i++) {
    delete data[i]._id;
}

// return first object 
if (data.length > 0) {
    mc.setPayloadJSON(data[0]);
} else {
    mc.setPayloadJSON({});
}
]]></script>
        </then>
        <else>
            <propertyGroup description="error details">
                <property value="404" name="ERROR_CODE" scope="default" type="STRING"/>
                <property value="Not Found" name="ERROR_MESSAGE" scope="default" type="STRING"/>
                <property value="Data not found for the given claimId" name="ERROR_DETAIL" scope="default" type="STRING"/>
            </propertyGroup>
            <call-template description="Error Log" target="Common-Log-Template-V1">
                <with-param name="service" value="claim-papi"/>
                <with-param name="sequence" value="claim-papi-getReserve-sequence"/>
                <with-param name="level" value="INFO"/>
                <with-param name="message" value="{$ctx:ERROR_MESSAGE}"/>
                <with-param name="status" value="ERROR"/>
            </call-template>
            <sequence key="claim-papi-common-fault-sequence"/>
        </else>
    </filter>
    <property name="LatencyMs" expression="get-property('SYSTEM_TIME') - get-property('StartTime')"/>
    <call-template target="Common-Log-Template-V1">
        <with-param name="service" value="claim-papi"/>
        <with-param name="sequence" value="claim-papi-getReserve-sequence"/>
        <with-param name="level" value="INFO"/>
        <with-param name="message" value="Ended claim-papi-getReserve-sequence"/>
        <with-param name="status" value="End"/>
    </call-template> 
</sequence>