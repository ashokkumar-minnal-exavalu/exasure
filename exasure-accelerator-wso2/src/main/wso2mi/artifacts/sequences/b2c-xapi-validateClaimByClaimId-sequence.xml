<?xml version="1.0" encoding="UTF-8"?>
<sequence name="b2c-xapi-validateClaimByClaimId-sequence" trace="disable" xmlns="http://ws.apache.org/ns/synapse">
    <filter xpath="${exists(params.pathParams.claimId)}">
        <then>
            <call-template target="Common-Log-Template-V1">
                <with-param name="service" value="b2c-xapi"/>
                <with-param name="sequence" value="b2c-xapi-validateClaimByClaimId-sequence"/>
                <with-param name="level" value="INFO"/>
                <with-param name="message" value="{${'Initiating b2c-xapi-validateClaimByClaimId-sequence for claimId: ' + params.pathParams.claimId}}"/>
                <with-param name="status" value="START"/>
            </call-template>
            <propertyGroup description="get_claims">
                <property name="HTTP_METHOD" scope="axis2" type="STRING" value="GET"/>
                <property name="REST_URL_POSTFIX" scope="axis2" type="STRING" expression="fn:concat('/claim/', get-property('uri.var.claimId'), '/validate')"/>
            </propertyGroup>
            <call>
                <endpoint key="claim-papi-restEndpoint"/>
            </call>
            <payloadFactory media-type="json">
                <format>$1</format>
                <args>
                    <arg evaluator="json" expression="json-eval($)"/>
                </args>
            </payloadFactory>
            <call-template target="Common-Log-Template-V1">
                <with-param name="service" value="b2c-xapi"/>
                <with-param name="sequence" value="b2c-xapi-validateClaimByClaimId-sequence"/>
                <with-param name="level" value="INFO"/>
                <with-param name="message" value="{${'Ending b2c-xapi-validateClaimByClaimId-sequence for claimId: ' + params.pathParams.claimId}}"/>
                <with-param name="status" value="END"/>
            </call-template>
            <respond/>
        </then>
        <else>
            <variable name="ERROR_CODE" type="STRING" value="VALIDATION_ERROR"/>
            <variable name="ERROR_MESSAGE" type="STRING" value="claimId parameter is missing"/>
            <variable name="ERROR_DETAIL" value="The claimId path parameter is required" type="STRING"/>
            <variable name="HTTP_SC" value="400" type="STRING"/>
            <sequence key="b2c-xapi-common-fault-sequence"/>
        </else>
    </filter>
</sequence>