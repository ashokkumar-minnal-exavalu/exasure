<?xml version="1.0" encoding="UTF-8"?>
<sequence name="general-ledger-sapi-update-GL-by-quoteId-sequence" xmlns="http://ws.apache.org/ns/synapse">
    <propertyGroup description="apiProperty">
        <property name="CorrelationID" expression="get-property('correlation_id')"/>
        <property name="LatencyMs" scope="default" type="STRING" value="0"/>
        <property name="StartTime" expression="get-property('SYSTEM_TIME')"/>
        <property name="quoteId" expression="get-property('uri.var.quoteId')" scope="default" type="STRING"/>
    </propertyGroup>
    <call-template target="Common-Log-Template-V1" description="start-log">
        <with-param name="service" value="general-ledger-sapi"/>
        <with-param name="sequence" value="general-ledger-sapi-update-GL-by-quoteId-sequence"/>
        <with-param name="level" value="INFO"/>
        <with-param name="message" value="{fn:concat('Initiating general-ledger-sapi-update-GL-by-quoteId-sequence for quoteId- ', $ctx:uri.var.quoteId)}"/>
        <with-param name="status" value="START"/>
    </call-template>
    <payloadFactory media-type="json">
        <format>
            {
            "$set": $1
            }
        </format>
        <args>
            <arg evaluator="json" expression="$"/>
        </args>
    </payloadFactory>
    <property name="updateQuery" expression="fn:concat('{&quot;quoteId&quot;:&quot;', $ctx:quoteId, '&quot;}')"/>
    <property name="updatePayload" expression="json-eval($)" scope="default" type="STRING"/>
    <mongodb.updateOne configKey="WSO2-MongoDB-Connection">
        <collection>GLpolicy</collection>
        <query>{$ctx:updateQuery}</query>
        <update>{$ctx:updatePayload}</update>
        <upsert>false</upsert>
        <responseVariable>mongoUpdateResult</responseVariable>
        <overwriteBody>true</overwriteBody>
    </mongodb.updateOne>
    <sequence key="general-ledger-sapi-get-GL-by-quoteId-sequence"/>
    <call-template target="Common-Log-Template-V1" description="end-log">
        <with-param name="service" value="general-ledger-sapi"/>
        <with-param name="sequence" value="general-ledger-sapi-update-GL-by-quoteId-sequence"/>
        <with-param name="level" value="INFO"/>
        <with-param name="message" value="{fn:concat('Ending general-ledger-sapi-update-GL-by-quoteId-sequence for quoteId- ', $ctx:uri.var.quoteId)}"/>
        <with-param name="status" value="END"/>
    </call-template>
</sequence>