<?xml version="1.0" encoding="UTF-8"?>
<sequence name="billing-payment-sapi-retrive-payout-sequence" trace="disable" xmlns="http://ws.apache.org/ns/synapse">
<call-template target="Common-Log-Template-V1" description="start-log">
        <with-param name="service" value="billing-payment-sapi"/>
        <with-param name="sequence" value="billing-payment-sapi-retrive-payout-sequence"/>
        <with-param name="level" value="INFO"/>
        <with-param name="message" value="Initiating billing-payment-sapi-retrive-payout-sequence"/>
        <with-param name="status" value="START"/>
    </call-template>
    <propertyGroup description="inputProperties">
        <property name="payoutId" expression="${params.pathParams.payoutId}" scope="default" type="STRING"/>
        <property name="HTTP_METHOD" scope="axis2" type="STRING" value="POST"/>
        <property name="REST_URL_POSTFIX" scope="axis2" type="STRING" expression="fn:concat('/v1/payouts/', $ctx:payoutId)"/>
        <property name="messageType" value="application/x-www-form-urlencoded" scope="axis2"/>
        <property name="ContentType" value="application/x-www-form-urlencoded" scope="axis2"/>
        <!-- Auth header -->
    </propertyGroup>
    <header name="Authorization" scope="transport" value="Bearer sk_test_51SdNv2Qsuyht91JMrQw97hGiY8ZGLbcdm0vdxQyd75JIqv0KX8n6I6oh9iec8Wu5VOO9OD6610K4ulsGAL6fwYSC00tKjpLaSa"/>
    <header name="Client-Type" scope="transport" value="application/x-www-form-urlencoded"/>
    <call>
        <endpoint key="stripe-api-restEndpoint"/>
    </call>
    <filter xpath="${properties.axis2.HTTP_SC == 200}">
        <then>
       
    <script language="js"><![CDATA[var backendResponse = mc.getPayloadJSON();
var response = {
  "payoutId": backendResponse.id,
  "amount": (backendResponse.amount)/100,
  "currency": backendResponse.currency,
  "arrivalDate": backendResponse.arrival_date ? new Date(backendResponse.arrival_date).toISOString() : null ,
  "balanceTransactionId": backendResponse.balance_transaction,
  "created": backendResponse.created ? new Date(backendResponse.created).toISOString() : null,
  "destinationId": backendResponse.destination,
  "method": backendResponse.method,
  "sourceType": backendResponse.source_type,
  "status": backendResponse.status
};            
mc.setPayloadJSON(response);
            ]]></script>
           </then>
 <else>
            <variable name="errorMsg" expression="${'Error occurred in claim-sapi for quoteId- ' + params.pathParams.claimId + ' errorMessage- ' + props.synapse.ERROR_MESSAGE + ' errorDetail- ' + props.synapse.ERROR_DETAIL + ' errorCode- ' + string(props.synapse.ERROR_CODE)}" type="STRING"/>
            <propertyGroup>
                <property name="ERROR_MESSAGE" scope="axis2" type="STRING" expression="${payload.error.message}" action="set"/>
                <property name="ERROR_DETAIL" scope="axis2" type="STRING" expression="${payload.error.message}" action="set"/>
                <property name="ERROR_CODE" scope="axis2" type="STRING" expression="${properties.axis2.HTTP_SC}" action="set"/>
            </propertyGroup>
            <sequence key="billing-payment-sapi-common-fault-sequence"/>
        </else>
    </filter>
    <call-template target="Common-Log-Template-V1" description="end-log">
        <with-param name="service" value="billing-payment-sapi"/>
        <with-param name="sequence" value="billing-payment-sapi-retrive-payout-sequence"/>
        <with-param name="level" value="INFO"/>
        <with-param name="message" value="Ending billing-payment-sapi-retrive-payout-sequence"/>
        <with-param name="status" value="END"/>
    </call-template>
    <respond/>
</sequence>