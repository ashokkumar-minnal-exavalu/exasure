<?xml version="1.0" encoding="UTF-8"?>
<sequence name="patch-specific-policyHolder-papi-sequence" trace="disable" xmlns="http://ws.apache.org/ns/synapse">
    <log category="INFO" logMessageID="true" logFullPayload="true">
        <message>Starting the papi call for patch-specific-policyHolder-papi-sequence****</message>
    </log>
    <property name="policyHolderId" expression="get-property('uri.var.policyHolderId')"/>    
    <propertyGroup description="inputProperty">
        <property name="HTTP_METHOD" scope="axis2" type="STRING" value="PATCH"/>
        <property name="REST_URL_POSTFIX" scope="axis2" type="STRING" expression="fn:concat('/api/', get-property('policyHolderId'))"/>
    </propertyGroup>
    <call>
        <endpoint key="policyHolder-sapi-restEndpoint"/>
    </call>
    <property description="statusCode" expression="$axis2:HTTP_SC" name="statusCode" scope="default" type="STRING"/>
    <log category="INFO" logMessageID="true" logFullPayload="true">
        <message>status code returned from sapi****</message>
        <property description="statusCode" expression="$axis2:HTTP_SC" name="statusCode**" scope="default" type="STRING"/>
    </log>    
    <filter xpath="get-property('statusCode')='200'">
        <then>
            <payloadFactory description="Response poayload" media-type="json">
                <format>
					$1
				</format>
                <args>
                    <arg evaluator="json" expression="$"/>
                </args>
            </payloadFactory>
            <property name="isFound" expression="json-eval($.found)" scope="default"/>
            <filter xpath="$ctx:isFound = 'true'">
                <then>
                    <payloadFactory media-type="json">
                        <format>
                            {
                                "status": "completed",
                                "statusMessage": "Details updated successfully",
                                "statusCode": "200",
                                "policyHolderId": "$1",
                                "policyHolderDetails": {
                                    "firstName": "$2",
                                    "lastName": "$3",
                                    "dateOfBirth": "$4",
                                    "gender": "$5",
                                    "occupation": "$6",
                                    "maritalStatus": "$7",
                                    "email": "$8",
                                    "address": {
                                        "country": "$9",
                                        "state": "$10",
                                        "zipCode": "$11"
                                    }
                                }
                            }
                        </format>

                        <args>
                            <arg evaluator="json" expression="$.data.policyHolderId"/>
                            <arg evaluator="json" expression="$.data.policyHolderDetails.firstName"/>
                            <arg evaluator="json" expression="$.data.policyHolderDetails.lastName"/>
                            <arg evaluator="json" expression="$.data.policyHolderDetails.dateOfBirth"/>
                            <arg evaluator="json" expression="$.data.policyHolderDetails.gender"/>
                            <arg evaluator="json" expression="$.data.policyHolderDetails.occupation"/>
                            <arg evaluator="json" expression="$.data.policyHolderDetails.maritalStatus"/>
                            <arg evaluator="json" expression="$.data.policyHolderDetails.email"/>
                            <arg evaluator="json" expression="$.data.policyHolderDetails.address.country"/>
                            <arg evaluator="json" expression="$.data.policyHolderDetails.address.state"/>
                            <arg evaluator="json" expression="$.data.policyHolderDetails.address.zipCode"/>
                        </args>
                    </payloadFactory>
                </then>
                <else>
                    <payloadFactory description="Response poayload" media-type="json">
                        <format>
                            $1
                        </format>
                        <args>
                            <arg evaluator="json" expression="$"/>
                        </args>
                    </payloadFactory>
                </else>
            </filter>            
        </then>
        <else>
            <propertyGroup description="error details">
                <property expression="json-eval($.errors[0].errorCode)" name="ERROR_CODE" scope="default" type="STRING"/>
                <property expression="json-eval($.errors[0].errorMessage)" name="ERROR_MESSAGE" scope="default" type="STRING"/>
                <property expression="json-eval($.errors[0].errorDescription)" name="ERROR_DETAIL" scope="default" type="STRING"/>
            </propertyGroup>
            <sequence key="policyHolder-papi-fault-sequence"/>
        </else>
    </filter>
    <log category="INFO" logMessageID="true" logFullPayload="true">
        <message>Ending patch-specific-policyHolder-papi-sequence***********</message>
    </log>
</sequence>