<?xml version="1.0" encoding="UTF-8"?>
<sequence name="b2c-xapi-getAll-Claims-sequence" trace="disable" xmlns="http://ws.apache.org/ns/synapse">
	<call-template target="Common-Log-Template-V1" description="start_log">
		<with-param name="service" value="b2c-xapi"/>
		<with-param name="sequence" value="b2c-xapi-getAll-Claims-sequence"/>
		<with-param name="level" value="INFO"/>
		<with-param name="message" value="{${'Initiating b2c-xapi-getAll-Claims-sequence '}}"/>
		<with-param name="status" value="START"/>
	</call-template>
	<propertyGroup description="get_claims">
		<property name="HTTP_METHOD" scope="axis2" type="STRING" value="GET"/>
