<?xml version="1.0" encoding="UTF-8"?>
<sequence name="agent-compensations-sapi-createcompensationSequence" trace="disable" xmlns="http://ws.apache.org/ns/synapse">
<call-template target="Common-Log-Template-V1">
        <with-param name="service" value="agent-compensation-sapi-api"/>
        <with-param name="sequence" value="agent-compensations-sapi-createcompensationSequence"/>
        <with-param name="level" value="INFO"/>
        <with-param name="message" value="Started agent-compensations-sapi-createcompensationSequence"/>
        <with-param name="status" value="START"/>
    </call-template>
    
    <script language="js"><![CDATA[
var payload = mc.getPayloadJSON();

var now = new Date();

function pad(n){ return n<10 ? '0'+n : n; }

var ts = now.getFullYear().toString() +
         pad(now.getMonth()+1) +
         pad(now.getDate()) +
         pad(now.getHours()) +
         now.getMilliseconds();

payload.commissionIdentifier = "COM-" + ts;
payload.createdDate = now.toISOString().split("T")[0];

mc.setPayloadJSON(payload);
]]></script>
<filter source="json-eval($.agentIdentifier)" regex="^$">
    <then>
        <property name="ERROR_MESSAGE" value="Bad Request"/>
        <property value="The Input Payload is INVALID" name="ERROR_DETAIL" scope="default" type="STRING"/>
        <property value="400" name="ERROR_CODE" scope="default" type="STRING"/>
        <property name="HTTP_SC" value="400" scope="axis2"/>
         <sequence key="agent-compensation-sapi-fault-sequence"/>
    </then>
</filter>
    <mongodb.insertOne configKey="MongoDB-Connection-AgentCompensation-sapi-API">
        <collection>compensation</collection>
        <document>{json-eval($)}</document>
        <responseVariable>mongodb_insertOne_682</responseVariable>
        <overwriteBody>false</overwriteBody>
    </mongodb.insertOne>
<filter source="json-eval($)" regex="^$">
    <then>
        <propertyGroup description="error details">
            <property value="500" name="ERROR_CODE" scope="default" type="STRING"/>
            <property value="Internal Server Error" name="ERROR_MESSAGE" scope="default" type="STRING"/>
            <property value="Data insert failed" name="ERROR_DETAIL" scope="default" type="STRING"/>
        </propertyGroup>
        <sequence key="agent-compensation-sapi-fault-sequence"/>
    </then>
</filter>
<payloadFactory media-type="json">
    <format>
        {
          "commissionIdentifier": "$1",
          "agentIdentifier": "$2",
          "policyNumber": "$3",
          "commissionStatusCode": "$4",
          "payoutStatusCode": "$5",
          "commissionAmount": "$6",
          "currencyCode": "$7",
          "createdDate": "$8"
        }
    </format>
    <args>
        <arg evaluator="json" expression="$.commissionIdentifier"/>
        <arg evaluator="json" expression="$.agentIdentifier"/>
        <arg evaluator="json" expression="$.policyNumber"/>
        <arg evaluator="json" expression="$.commissionStatusCode"/>
        <arg evaluator="json" expression="$.payoutStatusCode"/>
        <arg evaluator="json" expression="$.commissionAmount"/>
        <arg evaluator="json" expression="$.currencyCode"/>
        <arg evaluator="json" expression="$.createdDate"/>
    </args>
</payloadFactory>
<call-template target="Common-Log-Template-V1">
    <with-param name="service" value="agent-compensation-sapi-api"/>
    <with-param name="sequence" value="agent-compensations-sapi-createcompensationSequence"/>
    <with-param name="level" value="INFO"/>
    <with-param name="message" value="Ended agent-compensations-sapi-createcompensationSequence"/>
    <with-param name="status" value="END"/>
</call-template>
</sequence>