<?xml version="1.0" encoding="UTF-8"?>
<sequence name="claim-papi-getClaimBypolicyHolderIdSequence" trace="disable" xmlns="http://ws.apache.org/ns/synapse">
	<call-template target="Common-Log-Template-V1" description="start-log">
		<with-param name="service" value="claim-api"/>
		<with-param name="sequence" value="getClaimByPolicyHolderIdSequence"/>
		<with-param name="level" value="INFO"/>
		<with-param name="message" value="Initiating getClaimByPolicyHolderIdSequence"/>
		<with-param name="status" value="START"/>
	</call-template>
	<property name="policyHolderId" expression="get-property('uri.var.policyHolderId')"/>
	<propertyGroup description="inputProperties">
		<property name="HTTP_METHOD" scope="axis2" type="STRING" value="GET"/>
		<property name="REST_URL_POSTFIX" scope="axis2" type="STRING" expression="concat('/claim/policyHolder/',  $ctx:policyHolderId)"/>
	</propertyGroup>
	<call>
		<endpoint key="claim-sapi-restEndpoint"/>
	</call>
	<filter source="get-property('axis2','HTTP_SC')" regex="2\d{2}">
		<then>
			<property name="claimRequests" expression="json-eval($.data[*].claimRequest)" scope="default" type="STRING"/>
			<payloadFactory media-type="json">
				<format>
					$1
				</format>
				<args>
					<arg evaluator="json" expression="$ctx:claimRequests"/>
				</args>
			</payloadFactory>
		</then>
		<else>
			<!-- FAILURE FLOW: return backend response as-is -->
			<respond/>
		</else>
	</filter>
	<call-template target="Common-Log-Template-V1" description="end-log">
		<with-param name="service" value="claim-api"/>
		<with-param name="sequence" value="getClaimByPolicyHolderIdSequence"/>
		<with-param name="level" value="INFO"/>
		<with-param name="message" value="Ending getClaimByPolicyHolderIdSequence"/>
		<with-param name="status" value="END"/>
	</call-template>
	<respond/>
</sequence>