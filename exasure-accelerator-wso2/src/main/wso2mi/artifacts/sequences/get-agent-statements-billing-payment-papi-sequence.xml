<?xml version="1.0" encoding="UTF-8"?>
<sequence name="get-agent-statements-billing-payment-papi-sequence" trace="disable" xmlns="http://ws.apache.org/ns/synapse">
    <propertyGroup description="apiProperty">
        <property name="CorrelationID" expression="get-property('correlation_id')"/>
        <property name="LatencyMs" scope="default" type="STRING" value="0"/>
        <property name="StartTime" expression="get-property('SYSTEM_TIME')"/>
        <property name="agentId" expression="get-property('uri.var.agentId')"/>
    </propertyGroup>
    <call-template target="Common-Log-Template-V1">
        <with-param name="service" value="billing-payment-papi-api"/>
        <with-param name="sequence" value="get-agent-statements-billing-payment-papi-sequence"/>
        <with-param name="level" value="INFO"/>
        <with-param name="message" value="Started get-agent-statements-billing-payment-papi-sequence"/>
        <with-param name="status" value="START"/>
    </call-template>
    <propertyGroup description="inputProperty">
        <property name="HTTP_METHOD" scope="axis2" type="STRING" value="GET"/>
        <property name="REST_URL_POSTFIX" scope="axis2" type="STRING" expression="fn:concat('/agents/', get-property('agentId'), '/statements')"/>
    </propertyGroup>
    <log category="INFO" logMessageID="true" logFullPayload="true">
        <message>Properties passed+++++++</message>
        <property name="REST_URL_POSTFIX+++++++++++" scope="axis2" type="STRING" expression="fn:concat('/agents/', get-property('agentId'), '/statements')"/>

    </log>
    <call>
        <endpoint key="agent-compensation-sapi-restEndpoint"/>
    </call>
    <log category="INFO" logMessageID="true" logFullPayload="true">
        <message>response received from agent-compensation-sapi-restEndpoint+++++++</message>

    </log>    
    <filter source="$axis2:HTTP_SC" regex="2\d\d">
        <then>
        </then>
        <else>
            <propertyGroup description="error details">
                <property expression="json-eval($.errors[0].errorCode)" name="ERROR_CODE" scope="default" type="STRING"/>
                <property expression="json-eval($.errors[0].errorMessage)" name="ERROR_MESSAGE" scope="default" type="STRING"/>
                <property expression="json-eval($.errors[0].errorDescription)" name="ERROR_DETAIL" scope="default" type="STRING"/>
            </propertyGroup>
            <call-template description="Error Log" target="Common-Log-Template-V1">
                <with-param name="service" value="billing-payment-papi-api"/>
                <with-param name="sequence" value="get-agent-statements-billing-payment-papi-sequence"/>
                <with-param name="level" value="INFO"/>
                <with-param name="message" value="{$ctx:ERROR_MESSAGE}"/>
                <with-param name="status" value="ERROR"/>
            </call-template>
            <sequence key="billing-payment-papi-fault-sequence"/>
        </else>
    </filter>    
    <property name="LatencyMs" expression="get-property('SYSTEM_TIME') - get-property('StartTime')"/>
    <call-template target="Common-Log-Template-V1">
        <with-param name="service" value="billing-payment-papi-api"/>
        <with-param name="sequence" value="get-agent-statements-billing-payment-papi-sequence"/>
        <with-param name="level" value="INFO"/>
        <with-param name="message" value="Ended get-agent-statements-billing-payment-papi-sequence"/>
        <with-param name="status" value="END"/>
    </call-template>
</sequence>