<?xml version="1.0" encoding="UTF-8"?>
<sequence name="invoice-sapi-get-all-invoices-by-quoteId-sequence" trace="disable" xmlns="http://ws.apache.org/ns/synapse">
    <property name="quoteId" expression="get-property('uri.var.quoteId')" scope="default" type="STRING"/>
    <call-template target="Common-Log-Template-V1" description="start-log">
        <with-param name="service" value="invoice-sapi"/>
        <with-param name="sequence" value="invoice-sapi-get-all-invoices-by-quoteId-sequence"/>
        <with-param name="level" value="INFO"/>
        <with-param name="message" value="{fn:concat('Initiating invoice-sapi-get-all-invoices-by-quoteId-sequence for quoteId- ', $ctx:uri.var.quoteId)}"/>
        <with-param name="status" value="START"/>
    </call-template>
    <property name="updateQuery" expression="fn:concat('{&quot;quoteId&quot;:&quot;', $ctx:quoteId, '&quot;}')"/>
    <mongodb.find configKey="WSO2-MongoDB-Connection">
        <collection>Invoice</collection>
        <query>{$ctx:updateQuery}</query>
        <projection></projection>
        <collation></collation>
        <limit></limit>
        <sort></sort>
        <responseVariable>mongodb_findData</responseVariable>
        <overwriteBody>true</overwriteBody>
    </mongodb.find>
    <filter source="json-eval($.found)" regex="true">
        <then>
            <!-- SUCCESS SCENARIO -->
            <enrich>
                <source type="custom" xpath="json-eval($.data)"/>
                <target type="body" action="replace"/>
            </enrich>
            <script language="js"><![CDATA[var payload = mc.getPayloadJSON();

payload.forEach(function(item){
    delete item._id;
});

mc.setPayloadJSON(payload);]]></script>
        </then>
        <else>
            <!-- ERROR SCENARIO -->
            <property name="messageType" value="application/json" scope="axis2"/>
            <property name="HTTP_SC" value="404" scope="axis2"/>
            <payloadFactory media-type="json">
                <format>
                    {
                    "errorCode": "404",
                    "errorMessage": "Data not found",
                    "errorDetails": "No invoice record forund for this quoteID.",
                    "transactionId": "$1",
                    "timeStamp": "$2"
                    }
                </format>
                <args>
                    <arg expression="get-property('correlation_id')"/>
                    <arg expression="get-property('SYSTEM_DATE')"/>
                </args>
            </payloadFactory>
        </else>
    </filter>
    <call-template target="Common-Log-Template-V1" description="end-log">
        <with-param name="service" value="invoice-sapi"/>
        <with-param name="sequence" value="invoice-sapi-get-all-invoices-by-quoteId-sequence"/>
        <with-param name="level" value="INFO"/>
        <with-param name="message" value="{fn:concat('Ending invoice-sapi-get-all-invoices-by-quoteId-sequence for quoteId- ', $ctx:uri.var.quoteId)}"/>
        <with-param name="status" value="END"/>
    </call-template>
</sequence>