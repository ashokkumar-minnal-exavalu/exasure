<?xml version="1.0" encoding="UTF-8"?>
<sequence name="receivables-sapi-updateReceivablesByQuoteId-sequence" trace="disable" xmlns="http://ws.apache.org/ns/synapse">
   <propertyGroup description="apiProperty">
        <property name="CorrelationID" expression="get-property('correlation_id')"/>
        <property name="LatencyMs" scope="default" type="STRING" value="0"/>
        <property name="StartTime" expression="get-property('SYSTEM_TIME')"/>
        <property name="quoteId" expression="get-property('uri.var.quoteId')" scope="default"/>
        <property name="receivableStatusCode" expression="json-eval($.receivableStatusCode)" scope="default"/>
        <property name="paymentDate" expression="json-eval($.paymentDate)" scope="default"/>
    </propertyGroup>
    <call-template target="Common-Log-Template-V1">
        <with-param name="service" value="receivables-sapi"/>
        <with-param name="sequence" value="receivables-sapi-updateReceivablesByQuoteId-sequence"/>
        <with-param name="level" value="INFO"/>
        <with-param name="message" value="Started receivables-sapi-updateReceivablesByQuoteId-sequence"/>
        <with-param name="status" value="START"/>
    </call-template>
<payloadFactory media-type="json">
    <format>
            {
            "$set": $1
            }
        </format>
    <args>
            <arg evaluator="json" expression="$"/>
        </args>
    </payloadFactory>
    <property name="mongoUpdate" expression="json-eval($)"/>
<payloadFactory media-type="json">
    <format>
            {
            "policy.quoteId": "$1"
            }
        </format>
    <args>
            <arg evaluator="xml" expression="get-property('quoteId')"/>
        </args>
    </payloadFactory>
    <property name="mongoQuery" expression="json-eval($)"/>
    <mongodb.updateOne configKey="MongoDB-Connection-receivables">
        <collection>receivables</collection>
        <query>{$ctx:mongoQuery}</query>
        <update>{$ctx:mongoUpdate}</update>
        <upsert>false</upsert>
        <collation></collation>
        <arrayFilters></arrayFilters>
        <responseVariable>mongodb_updateOne_1</responseVariable>
        <overwriteBody>true</overwriteBody>
    </mongodb.updateOne>
    <filter source="json-eval($.modifiedCount)" regex="^(?!0$).*">
        <then>
<payloadFactory media-type="json">
    <format>
        {
          "receivableStatusCode": "$1",
          "lastUpdatedDateTime": "$2",
          "paymentDate": "$3",
          "message": "Receivable record updated successfully"
        }
    </format>
    <args>
        <arg evaluator="xml" expression="get-property('receivableStatusCode')"/>
        <arg evaluator="xml" expression="get-property('SYSTEM_DATE', 'yyyy-MM-dd')"/>
        <arg evaluator="xml" expression="get-property('paymentDate')"/>
    </args>
</payloadFactory>
        </then>
        <else>
        <propertyGroup description="error details">
            <property value="400" name="ERROR_CODE" scope="default" type="STRING"/>
            <property value="Failed to update Receivables" name="ERROR_MESSAGE" scope="default" type="STRING"/>
            <property value="Failed to update Receivables !!! Try again" name="ERROR_DETAIL" scope="default" type="STRING"/>
        </propertyGroup>
        <call-template description="Error Log" target="Common-Log-Template-V1">
            <with-param name="service" value="receivables-sapi"/>
            <with-param name="sequence" value="receivables-sapi-updateReceivablesByQuoteId-sequence"/>
            <with-param name="level" value="INFO"/>
            <with-param name="message" value="{$ctx:ERROR_MESSAGE}"/>
            <with-param name="status" value="ERROR"/>
        </call-template>
        <sequence key="receivables-sapi-fault-sequence"/>
        </else>
    </filter>
    <property name="LatencyMs" expression="get-property('SYSTEM_TIME') - get-property('StartTime')"/>
    <call-template target="Common-Log-Template-V1">
        <with-param name="service" value="receivables-sapi"/>
        <with-param name="sequence" value="receivables-sapi-updateReceivablesByQuoteId-sequence"/>
        <with-param name="level" value="INFO"/>
        <with-param name="message" value="END receivables-sapi-updateReceivablesByQuoteId-sequence"/>
        <with-param name="status" value="Ended"/>
    </call-template>
</sequence>