<?xml version="1.0" encoding="UTF-8"?>
<sequence name="agent-compensations-sapi-fetchallagentstatementSequence" trace="disable" xmlns="http://ws.apache.org/ns/synapse">
<script language="js"><![CDATA[
var UUID = Java.type("java.util.UUID");
mc.setProperty("uuid", UUID.randomUUID().toString());
]]></script>
<property name="uuid" expression="get-property('uuid')" scope="default"/>
<log><property name="uuid" expression="get-property('uuid')" scope="default"/></log>
<call-template target="Common-Log-Template-V1">
        <with-param name="service" value="agent-compensation-sapi-api"/>
        <with-param name="sequence" value="agent-compensations-sapi-fetchallagentstatementSequence"/>
        <with-param name="level" value="INFO"/>
        <with-param name="message" value="Started agent-compensations-sapi-fetchallagentstatementSequence"/>
        <with-param name="status" value="START"/>
</call-template>
<payloadFactory media-type="json">
   <format>
   {"_id":"lastProcessedTs"}
   </format>
   <args>
      
   </args>
</payloadFactory>
<property name="mongotimeQuery" type="STRING" expression="json-eval($)"/>
<mongodb.find configKey="MongoDB-Connection-AgentCompensation-sapi-API">
        <collection>agentStatementState</collection>
        <query>{$ctx:mongotimeQuery}</query>
        <projection></projection>
        <responseVariable>state_result</responseVariable>
        <overwriteBody>true</overwriteBody>
    </mongodb.find>
    <property name="lastProcessedTs"
              expression="json-eval($.data[0].value)"
              scope="default"/>
             
    <log level="full">
        <property name="lastProcessedTs" expression="$ctx:lastProcessedTs"/>
    </log>

 <filter xpath="not(boolean(get-property('lastProcessedTs')))">
    <then>
            <property name="lastProcessedTs" value="1704067200" scope="default" />
        </then>
</filter>
<payloadFactory media-type="json">
   <format>
   {
      "generatedDate":{
         "$gt":$1
      }
   }
   </format>
   <args>
      <arg expression="$ctx:lastProcessedTs" evaluator="xml"/>
   </args>
</payloadFactory>
<property name="mongoQuery" type="STRING" expression="json-eval($)"/>
    <mongodb.find configKey="MongoDB-Connection-AgentCompensation-sapi-API">
        <collection>agentStatements</collection>
        <query>{$ctx:mongoQuery}</query>
        <projection></projection>
        <collation></collation>
        <limit></limit>
        <sort></sort>
        <responseVariable>mongodb_find_179</responseVariable>
        <overwriteBody>true</overwriteBody>
    </mongodb.find>

            <script language="js"><![CDATA[
var payload = mc.getPayloadJSON() || {};
var arr = payload.data || [];

for (var i = 0; i < arr.length; i++) {
    delete arr[i]._id;
}
// Save transformed response for later
mc.setProperty("findResult", JSON.stringify(arr));
mc.setPayloadJSON(arr);
]]></script>
<filter source="json-eval($.data)" regex="^\[\s*\]$">
     <then>
        <log level="custom">
            <property name="Info" value="No records found. Timestamp not updated"/>
            </log>
        </then>

    <else>
            <property name="currentTime"
                expression="get-property('SYSTEM_TIME')"
                scope="default" />

            <log level="custom">
                <property name="Info" value="Records found. Updating MongoDB state" />
                <property name="currentTime" expression="$ctx:currentTime" />
            </log>
<payloadFactory media-type="json">
   <format>
                    { "$set": { "value": $1 } } </format>
   <args>
      <arg expression="$ctx:currentTime" evaluator="xml"/>
                </args>
            </payloadFactory>
<property name="mongoDocUpdate" type="STRING" expression="json-eval($)"/>

            <mongodb.updateOne configKey="MongoDB-Connection-AgentCompensation-sapi-API">
                <collection>agentStatementState</collection>
                <query>{$ctx:mongotimeQuery}</query>
                <update>{$ctx:mongoDocUpdate}</update>
                <upsert>True</upsert>
                <collation></collation>
                <arrayFilters></arrayFilters>
                <responseVariable>mongodb_updateOne_921</responseVariable>
                <overwriteBody>false</overwriteBody>
            </mongodb.updateOne>
        </else>
    </filter>
    <payloadFactory media-type="json">
   <format>
       $1 </format>
   <args>
      <arg expression="$ctx:findResult" evaluator="xml"/>
                </args>
            </payloadFactory>
    
<call-template target="Common-Log-Template-V1">
    <with-param name="service" value="agent-compensation-sapi-api"/>
    <with-param name="sequence" value="agent-compensations-sapi-fetchallagentstatementSequence"/>
    <with-param name="level" value="INFO"/>
    <with-param name="message" value="Ended agent-compensations-sapi-fetchallagentstatementSequence"/>
    <with-param name="status" value="END"/>
    </call-template>
</sequence>