<?xml version="1.0" encoding="UTF-8"?>
<sequence name="claim-papi-create-payable-sequence" trace="disable" xmlns="http://ws.apache.org/ns/synapse">
    <call-template target="Common-Log-Template-V1" description="start-log">
        <with-param name="service" value="claim-api"/>
        <with-param name="sequence" value="claim-papi-create-payable-sequence"/>
        <with-param name="level" value="INFO"/>
        <with-param name="message" value="Initiating claim-papi-create-payable-sequence"/>
        <with-param name="status" value="START"/>
    </call-template>
	<propertyGroup>
        <property name="inputData" expression="json-eval($)" scope="default"/>
		<property name="approvalMessage" expression="json-eval($.approvalMessage)" scope="default" type="STRING">
        </property>
        <property name="claimId" expression="get-property('uri.var.claimId')"/>
        <property name="ContentType" value="application/x-www-form-urlencoded" scope="axis2"/>
        <property name="HTTP_METHOD" scope="axis2" type="STRING" value="GET"/>
        <property name="REST_URL_POSTFIX" scope="axis2" type="STRING" expression="concat('/api/claim/', $ctx:claimId, '/inspection-reports')"/>
        <property name="StartTime" expression="get-property('SYSTEM_TIME')" scope="default" type="STRING"/>
        <property name="LatencyMs" value="0" scope="default" type="STRING"/>
    </propertyGroup>
	<call>
        <endpoint key="claim-assessment-sapi-restEndpoint"/>
    </call>

    <!-- Store inspection response -->
    <property name="inspection" expression="json-eval($)" scope="default" type="STRING"/>
    <property name="HTTP_METHOD" scope="axis2" type="STRING" value="GET"/>
    <property name="REST_URL_POSTFIX" scope="axis2" type="STRING" expression="concat('/claim/', $ctx:claimId)"/>
    <!-- Step 2: Get Claim Details -->
    <call>
        <endpoint key="claim-sapi-restEndpoint"/>
    </call>
    <!-- Store claim details -->
    <property name="claimDetails" expression="json-eval($.data)" scope="default" type="STRING"/>
    <log category="INFO" level="custom">
        <property name="claimDetails" expression="$ctx:claimDetails"/>
    </log>
    <!-- Step 3: Transform Payload (equivalent to DataWeave) -->
    <script language="js"><![CDATA[
        var inspection = JSON.parse(mc.getProperty("inspection"));
        var claimDetails = JSON.parse(mc.getProperty("claimDetails"));
        mc.setProperty("policyNumber", claimDetails[0].claimRequest.policy.policyNumber);

        var now = new Date();
        var payableId = "PAY" + now.getTime();

        var dueDate = new Date();
        dueDate.setDate(dueDate.getDate() + 15);

        function formatDate(d) {
            var month = '' + (d.getMonth() + 1);
            var day = '' + d.getDate();
            var year = d.getFullYear();

            if (month.length < 2) month = '0' + month;
            if (day.length < 2) day = '0' + day;

            return [year, month, day].join('-');
        }

        var payload = {
            payableTypeCode: "CLAIM_PAYABLE",
            payableStatusCode: "OPEN",
            payableIdentifier: payableId,
            claim: {
                claimId: mc.getProperty("claimId")
            },
            parties: [
                {
                    partyIdentifier: claimDetails[0].claimRequest.parties[0].partyIdentifier,
                    roleTypeCode: claimDetails[0].claimRequest.parties[0].partyTypeCode
                }
            ],
            amounts: [
                {
                    amountTypeCode: "CLAIM_EXPENSE",
                    amountValue: inspection.assessment.netPayableAmount,
                    currencyCode: "USD"
                }
            ],
            totalAmount: {
                amountValue: inspection.assessment.netPayableAmount,
                currencyCode: "USD"
            },
            dueDate: formatDate(dueDate)
        };

        mc.setPayloadJSON(payload);
    ]]></script>
    <!-- Step 4: Create Payable -->
    <property name="HTTP_METHOD" scope="axis2" type="STRING" value="POST"/>
    <property name="REST_URL_POSTFIX" scope="axis2" type="STRING" value="/payables"/>
    <log category="INFO" logMessageID="false" logFullPayload="false">
        <message>${payload}</message>
    </log>
    <!-- Step 2: Get Claim Details -->
    <call>
		<endpoint key="payable-sapi-restEndpoint"/>
    </call>
    <!-- Logger -->
    <log level="full">
        <property name="PayableResponse" expression="json-eval($)"/>
    </log>
    <!-- Step 5: Store response -->
    <property name="payableResponse" expression="json-eval($)" scope="default"/>
    <property name="LatencyMs" expression="get-property('SYSTEM_TIME') - get-property('StartTime')" scope="default" type="STRING"/>
    <call-template target="Common-Log-Template-V1">
        <with-param name="service" value="claim-papi"/>
        <with-param name="sequence" value="claim-papi-create-payable-sequence"/>
        <with-param name="level" value="INFO"/>
        <with-param name="message" value="Completed claim-papi-create-payable-sequence"/>
        <with-param name="status" value="END"/>
    </call-template>
</sequence>
