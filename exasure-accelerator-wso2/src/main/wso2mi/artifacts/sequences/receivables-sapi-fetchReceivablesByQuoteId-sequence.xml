<?xml version="1.0" encoding="UTF-8"?>
<sequence name="receivables-sapi-fetchReceivablesByQuoteId-sequence" trace="disable" xmlns="http://ws.apache.org/ns/synapse">
   <propertyGroup description="apiProperty">
        <property name="CorrelationID" expression="get-property('correlation_id')"/>
        <property name="LatencyMs" scope="default" type="STRING" value="0"/>
        <property name="StartTime" expression="get-property('SYSTEM_TIME')"/>
        <property name="quoteId" expression="get-property('uri.var.quoteId')" scope="default"/>
    </propertyGroup>
    <call-template target="Common-Log-Template-V1">
        <with-param name="service" value="receivables-sapi"/>
        <with-param name="sequence" value="receivables-sapi-fetchReceivablesByQuoteId-sequence"/>
        <with-param name="level" value="INFO"/>
        <with-param name="message" value="Started receivables-sapi-fetchReceivablesByQuoteId-sequence"/>
        <with-param name="status" value="START"/>
    </call-template>
    <payloadFactory media-type="json">
    <format>
            {
            "policy.quoteId": "$1"
            }
        </format>
    <args>
            <arg evaluator="xml" expression="get-property('quoteId')"/>
        </args>
    </payloadFactory>
    <property name="mongoQuery" expression="json-eval($)"/>
    <mongodb.findOne configKey="MongoDB-Connection-receivables">
        <collection>receivables</collection>
        <query>{$ctx:mongoQuery}</query>
        <projection></projection>
        <collation></collation>
        <responseVariable>mongodb_findOne_1</responseVariable>
        <overwriteBody>true</overwriteBody>
    </mongodb.findOne>
    <property name="isFound" expression="json-eval($.found)" scope="default"/>
    <filter xpath="$ctx:isFound = 'true'">
        <then>
            <payloadFactory description="Response poayload" media-type="json">
                <format>
                    $1
                </format>
                <args>
                    <arg evaluator="json" expression="$.data"/>
                </args>
            </payloadFactory>
<script language="js"><![CDATA[
var payload = mc.getPayloadJSON();

// Remove _id field
delete payload._id;

mc.setPayloadJSON(payload);
]]></script>
        </then>
        <else>
            <propertyGroup description="error details">
                <property value="404" name="ERROR_CODE" scope="default" type="STRING"/>
                <property value="Not Found" name="ERROR_MESSAGE" scope="default" type="STRING"/>
                <property value="No receivables found for this quoteId" name="ERROR_DETAIL" scope="default" type="STRING"/>
            </propertyGroup>
            <call-template description="Error Log" target="Common-Log-Template-V1">
                <with-param name="service" value="receivables-sapi"/>
                <with-param name="sequence" value="receivables-sapi-fetchReceivablesByQuoteId-sequence"/>
                <with-param name="level" value="INFO"/>
                <with-param name="message" value="{$ctx:ERROR_MESSAGE}"/>
                <with-param name="status" value="ERROR"/>
            </call-template>
            <sequence key="receivables-sapi-fault-sequence"/>
        </else>
    </filter> 
	<property name="LatencyMs" expression="get-property('SYSTEM_TIME') - get-property('StartTime')"/>
    <call-template target="Common-Log-Template-V1">
        <with-param name="service" value="receivables-sapi"/>
        <with-param name="sequence" value="receivables-sapi-fetchReceivablesByQuoteId-sequence"/>
        <with-param name="level" value="INFO"/>
        <with-param name="message" value="END receivables-sapi-fetchReceivablesByQuoteId-sequence"/>
        <with-param name="status" value="Ended"/>
    </call-template>
</sequence>