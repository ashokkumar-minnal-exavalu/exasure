<?xml version="1.0" encoding="UTF-8"?>
<sequence name="fetch-refund-by-refundId-refund-sapi-sequence" trace="disable" xmlns="http://ws.apache.org/ns/synapse">
    <propertyGroup description="apiProperty">
        <property name="CorrelationID" expression="get-property('correlation_id')"/>
        <property name="LatencyMs" scope="default" type="STRING" value="0"/>
        <property name="StartTime" expression="get-property('SYSTEM_TIME')"/>
        <property name="refundId" expression="get-property('uri.var.refundId')"/>
        <property name="mongoQuery" type="STRING" expression="fn:concat('{&quot;refundId&quot;:&quot;', $ctx:refundId, '&quot;}')"/>
    </propertyGroup>
    <call-template target="Common-Log-Template-V1">
        <with-param name="service" value="refund-sapi-api"/>
        <with-param name="sequence" value="fetch-refund-by-refundId-refund-sapi-sequence"/>
        <with-param name="level" value="INFO"/>
        <with-param name="message" value="Started fetch-refund-by-refundId-refund-sapi-sequence"/>
        <with-param name="status" value="START"/>
    </call-template>
    <mongodb.findOne configKey="WSO2-Accelerator-DB">
        <collection>Refund</collection>
        <query>{$ctx:mongoQuery}</query>
        <projection>
            {
            "_id": 0
            }
        </projection>
        <collation></collation>
        <responseVariable>mongodb_findOne_1</responseVariable>
        <overwriteBody>true</overwriteBody>
    </mongodb.findOne>
    <log category="INFO" logMessageID="true" logFullPayload="true">
        <message>Response from Mongo+++++</message>
    </log>
    <property name="isFound" expression="json-eval($.found)" scope="default"/>
    <filter xpath="$ctx:isFound = 'true'">
        <then>
            <payloadFactory media-type="json">
                <format>
                    {
                        "refundId": "$1",
                        "amount": "$2",
                        "status": "$3"
                    }
                </format>
                <args>
                    <arg evaluator="json" expression="json-eval($.data.refundId)"/>
                    <arg evaluator="json" expression="json-eval($.data.amount)"/>
                    <arg evaluator="json" expression="json-eval($.data.status)"/>
                </args>
            </payloadFactory>
        </then>
        <else>
            <propertyGroup description="error details">
                <property value="404" name="ERROR_CODE" scope="default" type="STRING"/>
                <property value="Not Found" name="ERROR_MESSAGE" scope="default" type="STRING"/>
                <property value="No details found for the provided refundId" name="ERROR_DETAIL" scope="default" type="STRING"/>
                <property name="HTTP_SC" scope="axis2" type="STRING" action="set" value="404"/>
            </propertyGroup>
            <call-template description="Error Log" target="Common-Log-Template-V1">
                <with-param name="service" value="refund-sapi-api"/>
                <with-param name="sequence" value="fetch-refund-by-refundId-refund-sapi-sequence"/>
                <with-param name="level" value="INFO"/>
                <with-param name="message" value="{$ctx:ERROR_MESSAGE}"/>
                <with-param name="status" value="ERROR"/>
            </call-template>
            <sequence key="refund-sapi-fault-sequence"/>
        </else>
    </filter>

    <property name="LatencyMs" expression="get-property('SYSTEM_TIME') - get-property('StartTime')"/>
    <call-template target="Common-Log-Template-V1">
        <with-param name="service" value="refund-sapi-api"/>
        <with-param name="sequence" value="fetch-refund-by-refundId-refund-sapi-sequence"/>
        <with-param name="level" value="INFO"/>
        <with-param name="message" value="Ended fetch-refund-by-refundId-refund-sapi-sequence"/>
        <with-param name="status" value="END"/>
    </call-template>
</sequence>