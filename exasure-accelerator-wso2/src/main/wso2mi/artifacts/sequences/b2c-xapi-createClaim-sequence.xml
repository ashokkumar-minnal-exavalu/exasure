<?xml version="1.0" encoding="UTF-8"?>
<sequence name="b2c-xapi-createClaim-sequence" trace="disable" xmlns="http://ws.apache.org/ns/synapse">
	<!-- Validate JSON payload -->
	<filter xpath="get-property('axis2','messageType') = 'application/json'">
		<then>
			<call-template target="Common-Log-Template-V1">
				<with-param name="service" value="b2c-xapi"/>
				<with-param name="sequence" value="b2c-xapi-createClaim-sequence"/>
				<with-param name="level" value="INFO"/>
				<with-param name="message" value="Initiating b2c-xapi-createClaim-sequence"/>
				<with-param name="status" value="START"/>
			</call-template>
			<!-- <property name="Input-Payload" scope="default" type="STRING" expression="json-eval($)"/> -->
			<propertyGroup description="post_claim">
				<property name="HTTP_METHOD" scope="axis2" type="STRING" value="POST"/>
				<property name="REST_URL_POSTFIX" scope="axis2" type="STRING" value="/claim"/>
			</propertyGroup>
			<call>
				<endpoint key="claim-papi-restEndpoint"/>
			</call>
			<call-template target="Common-Log-Template-V1">
				<with-param name="service" value="b2c-xapi"/>
				<with-param name="sequence" value="b2c-xapi-createClaim-sequence"/>
				<with-param name="level" value="INFO"/>
				<with-param name="message" value="Ending b2c-xapi-createClaim-sequence"/>
				<with-param name="status" value="END"/>
			</call-template>
			<respond/>
		</then>
		<!-- Not JSON -->
		<else>
			<variable name="ERROR_CODE" type="STRING" value="INVALID_PAYLOAD"/>
			<variable name="ERROR_MESSAGE" type="STRING" value="Please send a valid JSON"/>
			<variable name="ERROR_DETAIL" type="STRING" value="Request payload must be of type application/json"/>
			<variable name="HTTP_SC" type="STRING" value="400"/>
			<sequence key="b2c-xapi-common-fault-sequence"/>
		</else>
	</filter>
</sequence>
