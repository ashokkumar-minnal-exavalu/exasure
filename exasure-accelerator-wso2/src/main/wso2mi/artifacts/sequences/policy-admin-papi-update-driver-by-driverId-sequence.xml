<?xml version="1.0" encoding="UTF-8"?>
<sequence name="policy-admin-papi-update-driver-by-driverId-sequence" trace="disable" xmlns="http://ws.apache.org/ns/synapse">
    <propertyGroup description="apiProperty">
        <property name="CorrelationID" expression="get-property('correlation_id')"/>
        <property name="LatencyMs" scope="default" type="STRING" value="0"/>
        <property name="StartTime" expression="get-property('SYSTEM_TIME')"/>
    </propertyGroup>
    <variable name="driverId" expression="${params.pathParams.driverId}" type="STRING"/>
    <call-template target="Common-Log-Template-V1">
        <with-param name="service" value="policy-api"/>
        <with-param name="sequence" value="policy-admin-papi-update-driver-by-driverId-sequence"/>
        <with-param name="level" value="INFO"/>
        <with-param name="message" value="{${'Initiating policy-admin-papi-update-driver-by-driverId-sequence for driverId: ' + vars.driverId}}"/>
        <with-param name="status" value="START"/>
    </call-template>
    <propertyGroup description="inputProperty">
        <property name="HTTP_METHOD" scope="axis2" type="STRING" value="PATCH"/>
        <property name="REST_URL_POSTFIX" scope="axis2" type="STRING" expression="${&quot;/drivers/&quot;+ vars.driverId}" action="set"/>
    </propertyGroup>
    <header name="X-Correlation-ID" action="set" scope="transport" expression="get-property('CorrelationID')"/>

    <call>
        <endpoint key="driver-management-sapi-restEndpoint"/>
    </call>
    <property name="EndTime" expression="get-property('SYSTEM_TIME')"/>
    <property name="LatencyMs" expression="get-property('EndTime') - get-property('StartTime')"/>
    
    <filter xpath="${properties.axis2.HTTP_SC == 200}">
        <then>
            <call-template target="Common-Log-Template-V1">
                <with-param name="service" value="policy-api"/>
                <with-param name="sequence" value="policy-admin-papi-update-driver-by-driverId-sequence"/>
                <with-param name="level" value="INFO"/>
                <with-param name="message" value="{${'Completed policy-admin-papi-update-driver-by-driverId-sequence for driverId: ' + vars.driverId}}"/>
                <with-param name="status" value="END"/>
            </call-template>
        </then>
        <else>
            <call-template target="Common-Log-Template-V1">
                <with-param name="service" value="policy-api"/>
                <with-param name="sequence" value="policy-admin-papi-update-driver-by-driverId-sequence"/>
                <with-param name="level" value="INFO"/>
                <with-param name="message" value="{${'Completed policy-admin-papi-update-driver-by-driverId-sequence for driverId: ' + vars.driverId}}"/>
                <with-param name="status" value="ERROR"/>
            </call-template>
        </else>
    </filter>
</sequence>