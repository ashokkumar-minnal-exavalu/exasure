<?xml version="1.0" encoding="UTF-8"?>
<sequence name="claim-papi-audit-sequence" trace="disable" xmlns="http://ws.apache.org/ns/synapse">
    <call-template target="Common-Log-Template-V1">
        <with-param name="service" value="claim-papi"/>
        <with-param name="sequence" value="claim-papi-audit-sequence"/>
        <with-param name="level" value="INFO"/>
        <with-param name="message" value="Start claim-papi-audit-sequence sequence"/>
        <with-param name="status" value="START"/>
    </call-template>
    <property name="StartTime" expression="get-property('SYSTEM_TIME')" scope="default" type="STRING"/>
    <property name="LatencyMs" value="0" scope="default" type="STRING"/>

    <!-- Step 1: Transform Payload (DataWeave → JS Script) -->
    <script language="js"><![CDATA[
        var now = new Date();
        var invoiceId = "INV" + now.getTime();

        var payload = {
            eventTypeCode: "CLAIM_INVOICE_CREATED",
            reference: {
                claimId: mc.getProperty("claimId"),
                invoiceId: invoiceId
            },
            sourceSystem: "PayblesAPI"
        };

        mc.setPayloadJSON(payload);
    ]]></script>

    <!-- Step 2: Log Payload -->
    <log level="full">
        <property name="AuditRequest" expression="json-eval($)"/>
    </log>

    <!-- Step 3: Call Audit API -->
    <property name="HTTP_METHOD" scope="axis2" type="STRING" value="POST"/>
	<property name="REST_URL_POSTFIX" scope="axis2" type="STRING" value="/audit-trail"/>
    <!-- Step 2: Get Claim Details -->
    <call>
		<endpoint key="audit-trail-sapi-restEndpoint"/>
	</call>

    <!-- Step 4: Log Response -->
    <log level="full">
        <property name="AuditResponse" expression="json-eval($)"/>
    </log>

    <!-- Step 5: Store response (equivalent to set-variable) -->
    <property name="auditResponse" expression="json-eval($)" scope="default"/>
    <property name="LatencyMs" expression="get-property('SYSTEM_TIME') - get-property('StartTime')" scope="default" type="STRING"/>
    <call-template target="Common-Log-Template-V1">
        <with-param name="service" value="claim-papi"/>
        <with-param name="sequence" value="claim-papi-audit-sequence"/>
        <with-param name="level" value="INFO"/>
        <with-param name="message" value="Completed claim-papi-audit-sequence sequence"/>
        <with-param name="status" value="END"/>
    </call-template>
</sequence>