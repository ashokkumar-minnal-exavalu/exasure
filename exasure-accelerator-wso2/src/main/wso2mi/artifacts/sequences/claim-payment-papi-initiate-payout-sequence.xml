<?xml version="1.0" encoding="UTF-8"?>
<sequence name="claim-payment-papi-initiate-payout-sequence" trace="disable" xmlns="http://ws.apache.org/ns/synapse">
    <property name="StartTime" expression="get-property('SYSTEM_TIME')"/>
    <property name="LatencyMs" value="0"/>
    
    <call-template target="Common-Log-Template-V1">
        <with-param name="service" value="claim-payment-sapi"/>
        <with-param name="sequence" value="claim-payment-papi-initiate-payout-sequence"/>
        <with-param name="level" value="INFO"/>
        <with-param name="message" value="{${&quot;Initiating claim-payment-papi-initiate-payout-sequence for claimId: &quot; + properties.synapse.claimId}}"/>
        <with-param name="status" value="START"/>
    </call-template>
    <script language="js"><![CDATA[
      var initPayload = JSON.parse(mc.getProperty("initialpayload"));
      var payoutDestId = mc.getProperty("payoutDestinationId") || "";
      var body = {
        "claimAmount":         initPayload.payment ? initPayload.payment.claimAmount : "",
        "currency":            (initPayload.payment && initPayload.payment.currency) ? initPayload.payment.currency : "",
        "payoutDestinationId": payoutDestId
      };
      mc.setPayloadJSON(body);
    ]]></script>
    <log category="INFO" logMessageID="false" logFullPayload="false">
        <message>${payload}</message>
    </log>
    <property name="REST_URL_POSTFIX" scope="axis2" action="remove"/>
    <property name="HTTP_METHOD" value="POST" scope="axis2"/>
    <property name="REST_URL_POSTFIX" scope="axis2" type="STRING" value="/api/payment/payout"/>
    <property name="messageType" value="application/json" scope="axis2"/>
    <property name="ContentType" value="application/json" scope="axis2"/>
    <header name="Idempotency-Key" action="remove" scope="transport"/>

    <call>
        <endpoint key="claim-payment-sapi-restEndpoint"/>
    </call>
    <property name="paymentId" expression="json-eval($.paymentId)" scope="default" type="STRING"/>
    <property name="LatencyMs" expression="get-property('SYSTEM_TIME') - get-property('StartTime')"/>

    <call-template target="Common-Log-Template-V1">
        <with-param name="service" value="claim-payment-sapi"/>
        <with-param name="sequence" value="claim-payment-papi-initiate-payout-sequence"/>
        <with-param name="level" value="INFO"/>
        <with-param name="message" value="{${&quot;Ending claim-payment-papi-initiate-payout-sequence for claimId: &quot; + properties.synapse.claimId}}"/>
        <with-param name="status" value="END"/>
    </call-template>
    <clone continueParent="true">
      <target>
        <sequence>
        <sequence key="claim-payment-papi-response-log-sequence"/>
            </sequence>
        </target>
    </clone>
    
</sequence>