<?xml version="1.0" encoding="UTF-8"?>
<sequence name="claim-assessment-sapi-postLossItemsByClaimId-sequence" trace="disable" xmlns="http://ws.apache.org/ns/synapse">
   <propertyGroup description="apiProperty">
        <property name="CorrelationID" expression="get-property('correlation_id')"/>
        <property name="LatencyMs" scope="default" type="STRING" value="0"/>
        <property name="StartTime" expression="get-property('SYSTEM_TIME')"/>
        <property name="claimId" expression="get-property('uri.var.claimId')"/>
    </propertyGroup>
    <call-template target="Common-Log-Template-V1">
        <with-param name="service" value="claim-assessment-sapi"/>
        <with-param name="sequence" value="claim-assessment-sapi-postLossItemsByClaimId-sequence"/>
        <with-param name="level" value="INFO"/>
        <with-param name="message" value="Started claim-assessment-sapi-postLossItemsByClaimId-sequence"/>
        <with-param name="status" value="START"/>
    </call-template>
<script language="js"><![CDATA[
    var payload = mc.getPayloadJSON();
    var claimId = mc.getProperty("claimId");

    payload.claimId = claimId;

    mc.setPayloadJSON(payload);
]]></script>
    <property name="mongoInsert" expression="json-eval($)" scope="default"/>
    <mongodb.insertOne configKey="MongoDB-Connection-claimassessment">
        <collection>lossItems</collection>
        <document>{$ctx:mongoInsert}</document>
        <responseVariable>mongodb_insertOne_1</responseVariable>
        <overwriteBody>true</overwriteBody>
    </mongodb.insertOne>
    <property name="insertedCount" expression="json-eval($.insertedCount)" scope="default"/>

<filter xpath="$ctx:insertedCount = 1">
    <then>
    <property name="mongoQuery" type="STRING" expression="fn:concat('{&quot;claimId&quot;:&quot;', $ctx:claimId, '&quot;}')"/>
    <mongodb.find configKey="MongoDB-Connection-claimassessment">
        <collection>lossItems</collection>
        <query>{$ctx:mongoQuery}</query>
        <projection></projection>
        <collation></collation>
        <limit></limit>
        <sort></sort>
        <responseVariable>mongodb_find_1</responseVariable>
        <overwriteBody>true</overwriteBody>
    </mongodb.find>
<log category="INFO" level="custom"  description="MongoResponse">
    <property name="MongoFindResponse"  expression="json-eval($)"   />
</log>
    <property name="isFound" expression="json-eval($.found)" scope="default"/>
    <filter xpath="$ctx:isFound = 'true'">
    <then>
                    <property name="firstItem" expression="json-eval($.data[0])"/>
                    <payloadFactory description="Response poayload" media-type="json" template-type="Default">
                        <format>
                            {
                            "lossItemIdentifier": "$1",
                            "insurableObjectIdentifier": "$2",
                            "coverageIdentifier": "$3",
                            "lossTypeCode": "$4",
                            "claimId": "$5",
                            "isSuccessful": "true",
                            "message": "loss item is added successfully"
                            }
                        </format>
                        <args>
                            <arg expression="json-eval($ctx:firstItem.lossItemIdentifier)" evaluator="json"/>
                            <arg expression="json-eval($ctx:firstItem.insurableObjectIdentifier)" evaluator="json"/>
                            <arg expression="json-eval($ctx:firstItem.coverageIdentifier)" evaluator="json"/>
                            <arg expression="json-eval($ctx:firstItem.lossTypeCode)" evaluator="json"/>
                            <arg expression="json-eval($ctx:firstItem.claimId)" evaluator="json"/>
                        </args>
                    </payloadFactory>
                </then>
        <else>
            <propertyGroup description="error details">
                        <property value="404" name="ERROR_CODE" scope="default" type="STRING"/>
                        <property value="Not Found" name="ERROR_MESSAGE" scope="default" type="STRING"/>
                        <property value="No loss-item found for the given claimId" name="ERROR_DETAIL" scope="default" type="STRING"/>
                    </propertyGroup>
            <call-template description="Error Log" target="Common-Log-Template-V1">
                        <with-param name="service" value="claim-assessment-sapi"/>
                        <with-param name="sequence" value="claim-assessment-sapi-postLossItemsByClaimId-sequence"/>
                        <with-param name="level" value="INFO"/>
                        <with-param name="message" value="{$ctx:ERROR_MESSAGE}"/>
                        <with-param name="status" value="ERROR"/>
                    </call-template>
                    <sequence key="claim-assessment-sapi-fault-sequence"/>
                </else>
    </filter>
        </then>
    <else>
            <propertyGroup description="error details">
                <property value="404" name="ERROR_CODE" scope="default" type="STRING"/>
                <property value="Insert failed" name="ERROR_MESSAGE" scope="default" type="STRING"/>
                <property value="loss-items creation is failed for the given claimId" name="ERROR_DETAIL" scope="default" type="STRING"/>
            </propertyGroup>
            <call-template description="Error Log" target="Common-Log-Template-V1">
                <with-param name="service" value="claim-assessment-sapi"/>
                <with-param name="sequence" value="claim-assessment-sapi-postLossItemsByClaimId-sequence"/>
                <with-param name="level" value="INFO"/>
                <with-param name="message" value="{$ctx:ERROR_MESSAGE}"/>
                <with-param name="status" value="ERROR"/>
            </call-template>
            <sequence key="claim-assessment-sapi-fault-sequence" />
        </else>
</filter>
<property name="LatencyMs" expression="get-property('SYSTEM_TIME') - get-property('StartTime')"/>
    <call-template target="Common-Log-Template-V1">
        <with-param name="service" value="claim-assessment-sapi"/>
        <with-param name="sequence" value="claim-assessment-sapi-postLossItemsByClaimId-sequence"/>
        <with-param name="level" value="INFO"/>
        <with-param name="message" value="END claim-assessment-sapi-postLossItemsByClaimId-sequence"/>
        <with-param name="status" value="Ended"/>
    </call-template>
</sequence>