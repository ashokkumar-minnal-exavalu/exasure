<?xml version="1.0" encoding="UTF-8"?>
<sequence name="retrieve_payout_sequence" trace="disable" xmlns="http://ws.apache.org/ns/synapse">
    <log level="custom">
        <property name="INFO" value="Starting retrieve_payout_sequence"/>
        <property name="PAYOUT_ID" expression="get-property('payoutId')"/>
    </log>
<propertyGroup description="clearOldHttpContext">
    <property name="TRANSPORT_HEADERS" scope="axis2" action="remove"/>
    <property name="HTTP_METHOD" scope="axis2" action="remove"/>
    <property name="REST_URL_POSTFIX" scope="axis2" action="remove"/>
    <property name="QUERY_STRING" scope="axis2" action="remove"/>
    <property name="REST_SUB_REQUEST_PATH" scope="axis2" action="remove"/>
    <property name="messageType" scope="axis2" action="remove"/>
    <property name="ContentType" scope="axis2" action="remove"/>
</propertyGroup>

<propertyGroup description="retrievePayoutInput">
    <property name="NO_ENTITY_BODY" scope="axis2" value="true"/>
    <property name="HTTP_METHOD" scope="axis2" value="GET"/>
    <property name="REST_URL_POSTFIX"
              scope="axis2"
              expression="fn:concat('/api/billing-payment/retrive-payout/', get-property('payoutId'))"/>
</propertyGroup>

<call blocking="true">
    <endpoint key="billing-payment-sapi-restEndpoint"/>
</call>
<property name="NO_ENTITY_BODY" scope="axis2" action="remove"/>
    <log level="custom">
        <property name="retrieve_payout_RESPONSE" expression="json-eval($)"/>
        <property name="INFO" value="Ending retrieve_payout_sequence"/>
    </log>
</sequence>
