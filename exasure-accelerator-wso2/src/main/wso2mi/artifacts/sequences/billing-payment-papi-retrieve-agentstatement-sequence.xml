<?xml version="1.0" encoding="UTF-8"?>
<sequence name="billing-payment-papi-retrieve-agentstatement-sequence" trace="disable" xmlns="http://ws.apache.org/ns/synapse">
   <propertyGroup description="apiProperty">
        <property name="CorrelationID" expression="get-property('correlation_id')"/>
        <property name="LatencyMs" scope="default" type="STRING" value="0"/>
        <property name="StartTime" expression="get-property('SYSTEM_TIME')"/>
        <property name="quoteId" expression="get-property('uri.var.quoteId')" scope="default"/>
    </propertyGroup>
    <call-template target="Common-Log-Template-V1">
        <with-param name="service" value="billing-payment-papi"/>
        <with-param name="sequence" value="billing-payment-papi-retrieve-agentstatement-sequence"/>
        <with-param name="level" value="INFO"/>
        <with-param name="message" value="Started billing-payment-papi-retrieve-agentstatement-sequence"/>
        <with-param name="status" value="START"/>
    </call-template>
	<propertyGroup description="inputProperty">
        <property name="HTTP_METHOD" scope="axis2" type="STRING" value="GET"/>
        <property name="REST_URL_POSTFIX" scope="axis2" type="STRING" expression="fn:concat('/agents/', get-property('quoteId'), '/agent-statements/quote')"/>
    </propertyGroup>
    <call>
        <endpoint key="agent-compensation-sapi-restEndpoint"/>
    </call>
    <filter source="get-property('axis2','HTTP_SC')" regex="^(200|201)$">
        <then>
<payloadFactory media-type="json">
    <format>$1</format>
    <args>
        <arg evaluator="json" expression="$"/>
    </args>
</payloadFactory>
        </then>
        <else>
        <propertyGroup description="error details">
                <property value="404" name="ERROR_CODE" scope="default" type="STRING"/>
                <property value="Not Found" name="ERROR_MESSAGE" scope="default" type="STRING"/>
                <property value="No statement found for this quoteId!" name="ERROR_DETAIL" scope="default" type="STRING"/>
            </propertyGroup>
        <call-template description="Error Log" target="Common-Log-Template-V1">
                <with-param name="service" value="billing-payment-papi"/>
                <with-param name="sequence" value="billing-payment-papi-retrieve-agentstatement-sequence"/>
                <with-param name="level" value="INFO"/>
                <with-param name="message" value="{$ctx:ERROR_MESSAGE}"/>
                <with-param name="status" value="ERROR"/>
            </call-template>
            <sequence key="billing-payment-papi-fault-sequence"/>
        </else>
    </filter>
    <property name="LatencyMs" expression="get-property('SYSTEM_TIME') - get-property('StartTime')"/>
    <call-template target="Common-Log-Template-V1">
        <with-param name="service" value="billing-payment-papi"/>
        <with-param name="sequence" value="billing-payment-papi-retrieve-agentstatement-sequence"/>
        <with-param name="level" value="INFO"/>
        <with-param name="message" value="END billing-payment-papi-retrieve-agentstatement-sequence"/>
        <with-param name="status" value="Ended"/>
    </call-template>
</sequence>