<?xml version="1.0" encoding="UTF-8"?>
<sequence name="get-all-policyHolder-papi-sequence" trace="disable" xmlns="http://ws.apache.org/ns/synapse">
    <propertyGroup description="apiProperty">
        <property name="CorrelationID" expression="get-property('correlation_id')"/>
        <property name="LatencyMs" scope="default" type="STRING" value="0"/>
        <property name="StartTime" expression="get-property('SYSTEM_TIME')"/>
    </propertyGroup>    
    <call-template target="Common-Log-Template-V1">
        <with-param name="service" value="policyHolder-api"/>
        <with-param name="sequence" value="get-all-policyHolder-papi-sequence"/>
        <with-param name="level" value="INFO"/>
        <with-param name="message" value="Started get-all-policyHolder-papi-sequence"/>
        <with-param name="status" value="START"/>
    </call-template>
    <propertyGroup description="inputProperty">
        <property name="HTTP_METHOD" scope="axis2" type="STRING" value="GET"/>
        <property name="REST_URL_POSTFIX" scope="axis2" type="STRING" value="/api/all/policyHolder"/>
    </propertyGroup>
    <call>
        <endpoint key="policyHolder-sapi-restEndpoint"/>
    </call>    
    <property name="isFound" expression="json-eval($.found)" scope="default"/>
    <filter xpath="$ctx:isFound = 'true'">
        <then>
            <script language="js"><![CDATA[
                var payload = mc.getPayloadJSON();

                var response = {
                    status: "completed",
                    statusMessage: "Details fetched successfully",
                    policyholders: []
                };

                if (payload && payload.found === true && payload.data && payload.data.length > 0) {

                    for (var i = 0; i < payload.data.length; i++) {

                        var item = payload.data[i];
                        var details = item.policyHolderDetails || {};

                        var policyHolderObj = {
                            policyHolderId: item.policyHolderId,
                            policyHolderDetails: {
                                firstName: details.firstName,
                                lastName: details.lastName,
                                email: details.email,
                                gender: details.gender,
                                dateOfBirth: details.dateOfBirth,
                                occupation: details.occupation,
                                maritalStatus: details.maritalStatus,
                                address: {
                                    country: details.address ? details.address.country : null,
                                    state: details.address ? details.address.state : null,
                                    zipCode: details.address ? details.address.zipCode : null
                                }
                            }
                        };

                        response.policyholders.push(policyHolderObj);
                    }

                    mc.setPayloadJSON(response);

                } else {
                    mc.setPayloadJSON({
                        status: "completed",
                        statusMessage: "No details found",
                        policyholders: []
                    });
                }
            ]]></script>
        </then>
        <else>
        <propertyGroup description="error details">
            <property expression="json-eval($.errors[0].errorCode)" name="ERROR_CODE" scope="default" type="STRING"/>
            <property expression="json-eval($.errors[0].errorMessage)" name="ERROR_MESSAGE" scope="default" type="STRING"/>
            <property expression="json-eval($.errors[0].errorDescription)" name="ERROR_DETAIL" scope="default" type="STRING"/>
        </propertyGroup>
        <call-template description="Error Log" target="Common-Log-Template-V1">
            <with-param name="service" value="policyHolder-api"/>
            <with-param name="sequence" value="get-all-policyHolder-papi-sequence"/>
            <with-param name="level" value="INFO"/>
            <with-param name="message" value="{$ctx:ERROR_MESSAGE}"/> 
            <with-param name="status" value="ERROR"/>
            </call-template>        
            <sequence key="policyHolder-papi-fault-sequence"/>
        </else>
    </filter>
    <property name="LatencyMs" expression="get-property('SYSTEM_TIME') - get-property('StartTime')"/>    
    <call-template target="Common-Log-Template-V1">
        <with-param name="service" value="policyHolder-api"/>
        <with-param name="sequence" value="get-all-policyHolder-papi-sequence"/>
        <with-param name="level" value="INFO"/>
        <with-param name="message" value="Ended get-all-policyHolder-papi-sequence"/>
        <with-param name="status" value="END"/>
    </call-template>
</sequence>