<?xml version="1.0" encoding="UTF-8"?>
<sequence name="billing-account-sapi-createBillingAccount-sequence" trace="disable" xmlns="http://ws.apache.org/ns/synapse">
   <propertyGroup description="apiProperty">
        <property name="CorrelationID" expression="get-property('correlation_id')"/>
        <property name="LatencyMs" scope="default" type="STRING" value="0"/>
        <property name="StartTime" expression="get-property('SYSTEM_TIME')"/>
        <property name="quoteId" expression="json-eval($.quoteId)" scope="default"/>
    </propertyGroup>
    <call-template target="Common-Log-Template-V1">
        <with-param name="service" value="billing-account-sapi"/>
        <with-param name="sequence" value="billing-account-sapi-createBillingAccount-sequence"/>
        <with-param name="level" value="INFO"/>
        <with-param name="message" value="Started billing-account-sapi-createBillingAccount-sequence"/>
        <with-param name="status" value="START"/>
    </call-template>
    <filter xpath="string($ctx:quoteId) = '' or $ctx:quoteId = 'null'">
    <then>
        <propertyGroup description="error details">
            <property value="404" name="ERROR_CODE" scope="default" type="STRING"/>
            <property value="Not Found" name="ERROR_MESSAGE" scope="default" type="STRING"/>
            <property value="quoteId must not be empty" name="ERROR_DETAIL" scope="default" type="STRING"/>
        </propertyGroup>
    <call-template description="Error Log" target="Common-Log-Template-V1">
        <with-param name="service" value="billing-account-sapi"/>
        <with-param name="sequence" value="billing-account-sapi-createBillingAccount-sequence"/>
        <with-param name="level" value="INFO"/>
        <with-param name="message" value="{$ctx:ERROR_MESSAGE}"/>
        <with-param name="status" value="ERROR"/>
    </call-template>
    <sequence key="billing-account-sapi-fault-sequence"/>
    </then>
    <else>
    <property name="InsertQuery" expression="json-eval($)" scope="default"/>
    <mongodb.insertOne configKey="MongoDB-Connection-billing-account">
        <collection>BillingAccount</collection>
        <document>{$ctx:InsertQuery}</document>
        <responseVariable>mongodb_insertOne_1</responseVariable>
        <overwriteBody>true</overwriteBody>
    </mongodb.insertOne>
    <property name="insertedCount" expression="json-eval($.insertedCount)" scope="default"/>
    <filter xpath="$ctx:insertedCount = 1">
    <then>
    <property name="mongoQuery" type="STRING" expression="fn:concat('{&quot;quoteId&quot;:&quot;', $ctx:quoteId, '&quot;}')"/>
    <mongodb.find configKey="MongoDB-Connection-billing-account">
        <collection>BillingAccount</collection>
        <query>{$ctx:mongoQuery}</query>
        <projection></projection>
        <collation></collation>
        <limit></limit>
        <sort></sort>
        <responseVariable>mongodb_find_1</responseVariable>
        <overwriteBody>true</overwriteBody>
    </mongodb.find>
    <log category="INFO" level="custom"  description="MongoResponse">
        <property name="MongoFindResponse" expression="json-eval($)"/>
    </log>
    <property name="isFound" expression="json-eval($.found)" scope="default"/>
<filter xpath="$ctx:isFound = 'true'">
    <then>
<payloadFactory media-type="json">
    <format>$1</format>
    <args>
        <arg evaluator="json" expression="$.data[0]"/>
    </args>
</payloadFactory>
    </then>
    <else>
        <propertyGroup description="error details">
            <property value="404" name="ERROR_CODE" scope="default" type="STRING"/>
            <property value="Not Found" name="ERROR_MESSAGE" scope="default" type="STRING"/>
            <property value="No BillingAccount found for the given quoteId" name="ERROR_DETAIL" scope="default" type="STRING"/>
        </propertyGroup>
        <call-template description="Error Log" target="Common-Log-Template-V1">
            <with-param name="service" value="billing-account-sapi"/>
            <with-param name="sequence" value="billing-account-sapi-createBillingAccount-sequence"/>
            <with-param name="level" value="INFO"/>
            <with-param name="message" value="{$ctx:ERROR_MESSAGE}"/>
            <with-param name="status" value="ERROR"/>
        </call-template>
        <sequence key="billing-account-sapi-fault-sequence"/>
        </else>
    </filter>
    </then>
    <else>
        <propertyGroup description="error details">
            <property value="404" name="ERROR_CODE" scope="default" type="STRING"/>
            <property value="Insert failed" name="ERROR_MESSAGE" scope="default" type="STRING"/>
            <property value="Data insert failed" name="ERROR_DETAIL" scope="default" type="STRING"/>
        </propertyGroup>
        <call-template description="Error Log" target="Common-Log-Template-V1">
            <with-param name="service" value="billing-account-sapi"/>
            <with-param name="sequence" value="billing-account-sapi-createBillingAccount-sequence"/>
            <with-param name="level" value="INFO"/>
            <with-param name="message" value="{$ctx:ERROR_MESSAGE}"/>
            <with-param name="status" value="ERROR"/>
        </call-template>
        <sequence key="billing-account-sapi-fault-sequence"/>
        </else>
    </filter>
    </else>
</filter>
	<property name="LatencyMs" expression="get-property('SYSTEM_TIME') - get-property('StartTime')"/>
    <call-template target="Common-Log-Template-V1">
        <with-param name="service" value="billing-account-sapi"/>
        <with-param name="sequence" value="billing-account-sapi-createBillingAccount-sequence"/>
        <with-param name="level" value="INFO"/>
        <with-param name="message" value="END billing-account-sapi-createBillingAccount-sequence"/>
        <with-param name="status" value="Ended"/>
    </call-template>
</sequence>