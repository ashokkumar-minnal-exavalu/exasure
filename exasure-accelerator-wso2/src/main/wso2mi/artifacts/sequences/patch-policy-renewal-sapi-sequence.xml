<?xml version="1.0" encoding="UTF-8"?>
<sequence name="patch-policy-renewal-sapi-sequence" trace="disable" xmlns="http://ws.apache.org/ns/synapse">

    <propertyGroup description="apiProperty">
        <property name="CorrelationID" expression="get-property('correlation_id')"/>
        <property name="LatencyMs" scope="default" type="STRING" value="0"/>
        <property name="StartTime" expression="get-property('SYSTEM_TIME')"/>
        <property name="renewalId" expression="get-property('uri.var.renewalId')" scope="default"/>
        <property name="policyNumber" expression="get-property('query.param.policyNumber')" scope="default"/>
        <property name="action" expression="get-property('query.param.action')" scope="default"/>
        <property name="updatePolicyPayload" expression="json-eval($)" scope="default"/>
        <property name="mongoQuery" type="STRING" expression="fn:concat('{&quot;renewalId&quot;:&quot;', $ctx:renewalId, '&quot;}')"/>
        <property name="mongoQuery-policyNumber" type="STRING" expression="fn:concat('{&quot;policyNumber&quot;:&quot;', $ctx:policyNumber, '&quot;}')"/>
    </propertyGroup>

    <call-template target="Common-Log-Template-V1">
        <with-param name="service" value="policy-renewal-api"/>
        <with-param name="sequence" value="patch-policy-renewal-sapi-sequence"/>
        <with-param name="level" value="INFO"/>
        <with-param name="message" value="Started patch-policy-renewal-sapi-sequence"/>
        <with-param name="status" value="START"/>
    </call-template>
    <filter xpath="$ctx:action = 'ACCEPT'">
        <then>
            <!-- Update Renewal Status -->
            <payloadFactory media-type="json">
                <format>
                    {
                    "$set": {
                    "renewalStatusCode":"ACCEPTED"
                    }
                    }
                </format>
                <args/>
            </payloadFactory>
            <property name="mongoUpdate" expression="json-eval($)" scope="default"/>

            <mongodb.updateOne configKey="Renewal-SAPI-Connection">
                <collection>renewal</collection>
                <query>{json-eval($ctx:mongoQuery)}</query>
                <update>{json-eval($ctx:mongoUpdate)}</update>
                <upsert>false</upsert>
                <responseVariable>mongodb_updateOne_22</responseVariable>
                <overwriteBody>true</overwriteBody>
            </mongodb.updateOne>

            <log level="custom">
                <property name="Message" value="Response from Accept renewal Update Operation"/>
                <property name="modifiedCount++++++++++" expression="json-eval($.modifiedCount)" scope="default"/>

            </log>

            <property name="modifiedCount" expression="json-eval($.modifiedCount)" scope="default"/>

            <filter xpath="$ctx:modifiedCount &gt; 0">

                <then>
                    <!-- Update Policies -->
                    <payloadFactory media-type="json">
                        <format>
                            {
                            "$set":  $1
                            }
                        </format>
                        <args>
                            <arg evaluator="json" expression="$ctx:updatePolicyPayload"/>   
                        </args>
                    </payloadFactory>
                    <property name="policymongoUpdate" expression="json-eval($)" scope="default"/>

                    <mongodb.updateOne configKey="Renewal-SAPI-Connection">
                        <collection>policies</collection>
                        <query>{$ctx:mongoQuery-policyNumber}</query>
                        <update>{json-eval($ctx:policymongoUpdate)}</update>
                        <upsert>false</upsert>
                        <responseVariable>mongodb_updateOne_23</responseVariable>
                        <overwriteBody>true</overwriteBody>
                    </mongodb.updateOne>
                    <!-- Call Document Service -->
                    <propertyGroup description="inputProperties">
                        <property name="HTTP_METHOD" scope="axis2" type="STRING" value="POST"/>
                        <property name="REST_URL_POSTFIX"
                                  scope="axis2"
                                  expression="concat('/policies/',$ctx:policyNumber,'/documents')"/>
                    </propertyGroup>

                    <call blocking="true">
                        <endpoint key="Document-service-restEndpoint"/>
                    </call>

                    <log level="full">
                        <property name="Message" value="Response from policy Document service"/>
                    </log>

                    <property name="statusCode" expression="$axis2:HTTP_SC" scope="default" type="STRING"/>
                    <filter xpath="$ctx:statusCode = '200'">
                        <then>
                            <payloadFactory media-type="json">
                                <format>$1</format>
                                <args>
                                    <arg evaluator="json" expression="$"/>
                                </args>
                            </payloadFactory>
                        </then>
                        <else>
                            <propertyGroup>
                                <property name="ERROR_CODE" expression="json-eval($.errors[0].errorCode)"/>
                                <property name="ERROR_MESSAGE" expression="json-eval($.errors[0].errorMessage)"/>
                                <property name="ERROR_DETAIL" expression="json-eval($.errors[0].errorDescription)"/>
                            </propertyGroup>
                            <call-template target="Common-Log-Template-V1">
                                <with-param name="service" value="policy-renewal-api"/>
                                <with-param name="sequence" value="patch-policy-renewal-sapi-sequence"/>
                                <with-param name="level" value="INFO"/>
                                <with-param name="message" value="{$ctx:ERROR_MESSAGE}"/>
                                <with-param name="status" value="ERROR"/>
                            </call-template>
                            <sequence key="policy-renewal-sapi-fault-sequence"/>
                        </else>
                    </filter>
                    <!-- Prepare document update -->
                    <payloadFactory media-type="json">
                        <format>
                            {
                            "$set": {
                            "documents": [{
                            "binaryData": "$1",
                            "documentTypeCode": "$2",
                            "displayName": "$3",
                            "type": "PDF",
                            "generatedDate": "$4"
                            }]
                            }
                            }
                        </format>

                        <args>
                            <arg evaluator="json" expression="$.data"/>
                            <arg evaluator="json" expression="$.fileName"/>
                            <arg expression="$ctx:policyNumber"/>
                            <arg expression="get-property('SYSTEM_DATE','yyyy-MM-dd')"/>
                        </args>
                    </payloadFactory>
                    <property name="updatePayload-policy" expression="json-eval($)" scope="default" type="STRING"/>
                    <mongodb.updateOne configKey="Renewal-SAPI-Connection">
                        <collection>policies</collection>
                        <query>{$ctx:mongoQuery-policyNumber}</query>
                        <update>{$ctx:updatePayload-policy}</update>
                        <upsert>false</upsert>
                        <responseVariable>UpdatePolicyCollectionResult</responseVariable>
                        <overwriteBody>true</overwriteBody>
                    </mongodb.updateOne>
                    <property name="modifiedCount" expression="json-eval($.modifiedCount)" scope="default"/>
                    <filter xpath="$ctx:modifiedCount &gt; 0">
                        <then>
                            <payloadFactory media-type="json">
                                <format>
                                    {
                                    "renewalId":"$1",
                                    "policyNumber":"$2",
                                    "renewalStatusCode":"ACCEPTED",
                                    "currentPolicyTermIdentifier":"$3",
                                    "message":"policy renewal successful"
                                    }
                                </format>
                                <args>
                                    <arg expression="$ctx:renewalId"/>
                                    <arg expression="$ctx:policyNumber"/>
                                    <arg evaluator="json"
                                         expression="json-eval($ctx:updatePolicyPayload.currentPolicyTermIdentifier)"/>
                                </args>
                            </payloadFactory>
                        </then>
                        <else>
                            <payloadFactory media-type="json">
                                <format>
                                    {
                                    "renewalId":"$1",
                                    "policyNumber":"$2",
                                    "renewalStatusCode":"ACCEPTED",
                                    "message":"policy is already renewed"
                                    }
                                </format>
                                <args>
                                    <arg expression="$ctx:renewalId"/>
                                    <arg expression="$ctx:policyNumber"/>
                                </args>
                            </payloadFactory>
                        </else>
                    </filter>
                </then>
                <else>
                    <payloadFactory media-type="json">
                        <format>
                            {
                            "renewalId":"$1",
                            "policyNumber":"$2",
                            "renewalStatusCode":"ACCEPTED",
                            "message":"renewal status is already 'ACCEPTED'"
                            }
                        </format>
                        <args>
                            <arg expression="$ctx:renewalId"/>
                            <arg expression="$ctx:policyNumber"/>
                        </args>
                    </payloadFactory>
                </else>
            </filter>
        </then>
        <else>
            <!-- Decline renewal -->
            <payloadFactory media-type="json">
                <format>
                    {
                    "$set": {
                    "renewalStatusCode":"DECLINED"
                    }
                    }
                </format>
                <args/>
            </payloadFactory>
            <property name="mongoUpdate" expression="json-eval($)" scope="default" type="STRING"/>
            <mongodb.updateOne configKey="Renewal-SAPI-Connection">
                <collection>renewal</collection>
                <query>{$ctx:mongoQuery}</query>
                <update>{$ctx:mongoUpdate}</update>
                <upsert>false</upsert>
                <responseVariable>mongodb_updateOne_22</responseVariable>
                <overwriteBody>true</overwriteBody>
            </mongodb.updateOne>
            <payloadFactory media-type="json">
                <format>
                    {
                    "renewalId":"$1",
                    "policyNumber":"$2",
                    "renewalStatusCode":"DECLINED",
                    "message":"action selected was 'DECLINED'"
                    }
                </format>
                <args>
                    <arg expression="$ctx:renewalId"/>
                    <arg expression="$ctx:policyNumber"/>
                </args>
            </payloadFactory>
        </else>
    </filter>
    <property name="LatencyMs" expression="get-property('SYSTEM_TIME') - get-property('StartTime')"/>
    <call-template target="Common-Log-Template-V1">
        <with-param name="service" value="policy-renewal-api"/>
        <with-param name="sequence" value="patch-policy-renewal-sapi-sequence"/>
        <with-param name="level" value="INFO"/>
        <with-param name="message" value="Ended patch-policy-renewal-sapi-sequence"/>
        <with-param name="status" value="END"/>
    </call-template>
</sequence>