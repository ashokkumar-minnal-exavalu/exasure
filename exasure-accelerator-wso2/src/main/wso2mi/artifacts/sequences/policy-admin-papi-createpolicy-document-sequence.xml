<?xml version="1.0" encoding="UTF-8"?>
<sequence name="policy-admin-papi-createpolicy-document-sequence" trace="disable" xmlns="http://ws.apache.org/ns/synapse">
    <propertyGroup description="apiProperty">
        <property name="CorrelationID" expression="get-property('correlation_id')"/>
        <property name="LatencyMs" scope="default" type="STRING" value="0"/>
        <property name="StartTime" expression="get-property('SYSTEM_TIME')"/>
        <property name="policyNumber" expression="get-property('uri.var.policyNumber')"/>
    </propertyGroup>
    <call-template target="Common-Log-Template-V1">
        <with-param name="service" value="policy-admin-papi"/>
        <with-param name="sequence" value="policy-admin-papi-createpolicy-document-sequence"/>
        <with-param name="level" value="INFO"/>
        <with-param name="message" value="Started policy-admin-papi-createpolicy-document-sequence"/>
        <with-param name="status" value="START"/>
    </call-template> 
        <propertyGroup description="inputProperty">
        <property name="HTTP_METHOD" scope="axis2" type="STRING" value="GET"/>
        <property name="REST_URL_POSTFIX" scope="axis2" type="STRING" expression="fn:concat('/api/', get-property('policyNumber'))"/>
    </propertyGroup>
    <call>
        <endpoint key="policy-papi-restEndpoint"/>
    </call>
        <property description="statusCode" expression="$axis2:HTTP_SC" name="statusCode" scope="default" type="STRING"/>
    <filter xpath="get-property('statusCode')='200'">
        <then>
            <class name="com.example.wso2.pdf.PolicyPdfGeneratorMediator"/>
    <propertyGroup description="apiProperty">
        <property name="data" expression="get-property('policyBinaryData')"/>
        <property name="quoteId" expression="json-eval($.quote.quoteId)"/>
        <property name="documentId" expression="fn:concat('DOC', get-property('SYSTEM_TIME'))"/>
        <property name="policyNumber" expression="get-property('policyNumber')"/>
        <property name="fileName" scope="default" type="STRING" value="POLICY_DOCUMENT"/>
    </propertyGroup>
    <payloadFactory media-type="json">
    <format>
    {
        "documentId": "$1",
        "policyNumber": "$2",
        "quoteId": "$3",
        "fileName": "$4",
        "data": "$5"
    }
    </format>
    <args>
        <arg expression="get-property('documentId')"/>
        <arg expression="get-property('policyNumber')"/>
        <arg expression="get-property('quoteId')"/>
        <arg expression="get-property('fileName')"/>
        <arg expression="get-property('data')"/>
    </args>
</payloadFactory>

<propertyGroup description="inputProperty">
    <property name="HTTP_METHOD" scope="axis2" type="STRING" value="POST"/>
    <property name="REST_URL_POSTFIX" scope="axis2" type="STRING" expression="fn:concat('/api/policies/', get-property('policyNumber'), '/documents')"/>
 </propertyGroup>
 <call>
    <endpoint key="policy-document-sapi-restEndpoint"/>
</call>
<property description="statusCode" expression="$axis2:HTTP_SC" name="statusCode" scope="default" type="STRING"/>
    <filter xpath="get-property('statusCode')='200'">
        <then>
                        <script language="js"><![CDATA[var doc = mc.getPayloadJSON().data[0];

var response = {
    documentId: doc.documentId,
    fileName: doc.fileName,
    data: doc.data
};

// Optional fields
if (doc.policyNumber) {
    response.policyNumber = doc.policyNumber;
}

if (doc.quoteId) {
    response.quoteId = doc.quoteId;
}

mc.setPayloadJSON(response);
]]></script>
        </then>
        <else>
            <propertyGroup description="error details">
                <property value="404" name="ERROR_CODE" scope="default" type="STRING"/>
                <property value="Not Found" name="ERROR_MESSAGE" scope="default" type="STRING"/>
                <property value="No Document exist in database" name="ERROR_DETAIL" scope="default" type="STRING"/>
                    </propertyGroup>
            <call-template description="Error Log" target="Common-Log-Template-V1">
                <with-param name="service" value="policy-admin-papi"/>
                <with-param name="sequence" value="policy-admin-papi-createpolicy-document-sequence"/>
                <with-param name="level" value="INFO"/>
                <with-param name="message" value="{$ctx:ERROR_MESSAGE}"/>
                <with-param name="status" value="ERROR"/>
                    </call-template>
            <sequence key="policy-admin-papi-fault-sequence"/>
                </else>
    </filter>
        </then>
        <else>
            <propertyGroup description="error details">
                <property value="404" name="ERROR_CODE" scope="default" type="STRING"/>
                <property value="Data not found for the given policyId" name="ERROR_MESSAGE" scope="default" type="STRING"/>
                <property value="The data requested is not found in database" name="ERROR_DETAIL" scope="default" type="STRING"/>
            </propertyGroup>
            <call-template description="Error Log" target="Common-Log-Template-V1">
                <with-param name="service" value="policy-admin-papi"/>
                <with-param name="sequence" value="policy-admin-papi-createpolicy-document-sequence"/>
                <with-param name="level" value="INFO"/>
                <with-param name="message" value="{$ctx:ERROR_MESSAGE}"/>
                <with-param name="status" value="ERROR"/>
            </call-template>
            <sequence key="policy-admin-papi-fault-sequence"/>
        </else>
    </filter>
 <property name="LatencyMs" expression="get-property('SYSTEM_TIME') - get-property('StartTime')"/>
    <call-template target="Common-Log-Template-V1">
        <with-param name="service" value="policy-admin-papi"/>
        <with-param name="sequence" value="policy-admin-papi-createpolicy-document-sequence"/>
        <with-param name="level" value="INFO"/>
        <with-param name="message" value="Ended policy-admin-papi-createpolicy-document-sequence"/>
        <with-param name="status" value="End"/>
    </call-template>
</sequence>