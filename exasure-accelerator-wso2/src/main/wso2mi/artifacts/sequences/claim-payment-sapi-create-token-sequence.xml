<?xml version="1.0" encoding="UTF-8"?>
<sequence name="claim-payment-sapi-create-token-sequence" trace="disable" xmlns="http://ws.apache.org/ns/synapse">
    
    <log level="custom">
        <property name="message" value="Initiating claim-payment-sapi-create-token-sequence"/>
    </log>
    <propertyGroup description="RequestPayload_Properties ">
        <property name="country" expression="json-eval($.country)"/>
        <property name="currency" expression="json-eval($.currency)"/>
        <property name="routing_number" expression="json-eval($.bankDetails.routingNumber)"/>
        <property name="account_number" expression="json-eval($.bankDetails.accountNumber)"/>
        <property name="account_holder_name" expression="json-eval($.bankDetails.accountHolderName)"/>
        <property name="account_holder_type" expression="json-eval($.bankDetails.accountHolderType)"/>
    </propertyGroup>
    <!-- Build Stripe request body -->
    <payloadFactory media-type="json">
        <format>
            {
            "bank_account[country]": "$1",
            "bank_account[currency]": "$2",
            "bank_account[routing_number]": "$3",
            "bank_account[account_number]": "$4",
            "bank_account[account_holder_name]": "$5",
            "bank_account[account_holder_type]": "$6"
            }
        </format>
        <args>
            <arg evaluator="xml" expression="get-property('country')"/>
            <arg evaluator="xml" expression="get-property('currency')"/>
            <arg evaluator="xml" expression="get-property('routing_number')"/>
            <arg evaluator="xml" expression="get-property('account_number')"/>
            <arg evaluator="xml" expression="get-property('account_holder_name')"/>
            <arg evaluator="xml" expression="get-property('account_holder_type')"/>
        </args>
    </payloadFactory>
    <!-- Set headers -->
<propertyGroup>
    <property name="messageType" value="application/x-www-form-urlencoded" scope="axis2"/>
    <property name="ContentType" value="application/x-www-form-urlencoded" scope="axis2"/>
    </propertyGroup>
    <!-- Auth header -->
    <header name="Authorization" scope="transport" value="Bearer sk_test_51SdNv2Qsuyht91JMrQw97hGiY8ZGLbcdm0vdxQyd75JIqv0KX8n6I6oh9iec8Wu5VOO9OD6610K4ulsGAL6fwYSC00tKjpLaSa"/>
    <!-- Log final payload -->
    <log level="full"/>
<propertyGroup>
    <property name="REST_URL_POSTFIX" action="remove" scope="axis2"/>
    <property name="DISABLE_CHUNKING" value="true" scope="axis2"/>
    </propertyGroup>
    <!-- Call Stripe -->
	
	<propertyGroup description="inputProperties">
        <property name="HTTP_METHOD" scope="axis2" type="STRING" value="POST"/>
        <property name="REST_URL_POSTFIX" scope="axis2" type="STRING" value="/v1/tokens"/>
    </propertyGroup>
	<call>
        <endpoint key="stripe-api-restEndpoint"/>
    </call> stripe-api-restEndpoint <!-- Log response -->
    <log level="full"/>
<propertyGroup>
    <property name="messageType" value="application/json" scope="axis2"/>
    <property name="ContentType" value="application/json" scope="axis2"/>
    <property name="HTTP_SC" value="201" scope="axis2"/>
    </propertyGroup>

<filter source="get-property('axis2','HTTP_SC')" regex="^(200|201)$">
        <then>
            <!-- Success Scenario -->
            <payloadFactory media-type="json">
                <format>
                    {
                    "tokenId": "$1",
                    "payoutDestinationId": "$2"
                    }
                </format>
                <args>
                    <arg evaluator="json" expression="$.id"/>
                    <arg evaluator="json" expression="$.bank_account.id"/>
                </args>
            </payloadFactory>
        </then>
        <else>
            <!-- Error Scenario -->
            <payloadFactory media-type="json">
                <format>
                    {
                    "errorCode": "$1",
                    "errorMessage": "$2",
                    "transactionId": "$3",
                    "timeStamp": "$4"
                    }
                </format>
                <args>
                    <arg expression="get-property('axis2','HTTP_SC')"/>
                    <arg expression="get-property('ERROR_MESSAGE')"/>
                    <arg expression="get-property('uuid')"/>
                    <arg expression="fn:current-dateTime()"/>
                </args>
            </payloadFactory>
        </else>
    </filter></sequence>