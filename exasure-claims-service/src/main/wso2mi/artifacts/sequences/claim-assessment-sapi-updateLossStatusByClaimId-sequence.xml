<?xml version="1.0" encoding="UTF-8"?>
<sequence name="claim-assessment-sapi-updateLossStatusByClaimId-sequence" trace="disable" xmlns="http://ws.apache.org/ns/synapse">
   <propertyGroup description="apiProperty">
        <property name="CorrelationID" expression="get-property('correlation_id')"/>
        <property name="LatencyMs" scope="default" type="STRING" value="0"/>
        <property name="StartTime" expression="get-property('SYSTEM_TIME')"/>
        <property name="claimId" expression="get-property('uri.var.claimId')"/>
        <property name="initPayload" expression="json-eval($)"/>
    </propertyGroup>
    <call-template target="Common-Log-Template-V1">
        <with-param name="service" value="claim-assessment-sapi"/>
        <with-param name="sequence" value="claim-assessment-sapi-updateLossStatusByClaimId-sequence"/>
        <with-param name="level" value="INFO"/>
        <with-param name="message" value="Started claim-assessment-sapi-updateLossStatusByClaimId-sequence"/>
        <with-param name="status" value="START"/>
    </call-template>
    <payloadFactory media-type="json">
    <format>
            {
            "$set": {
            "lossStatus": "$1"
            }
            }
        </format>
    <args>
            <arg evaluator="json" expression="json-eval($.lossStatus)"/>
        </args>
    </payloadFactory>
    <property name="mongoQuery" type="STRING" expression="fn:concat('{&quot;claimId&quot;:&quot;', $ctx:claimId, '&quot;}')"/>
    <property name="mongoUpdate" expression="json-eval($)"/>
    <mongodb.updateOne configKey="MongoDB-Connection-claimassessment">
        <collection>lossItems</collection>
        <query>{$ctx:mongoQuery}</query>
        <update>{$ctx:mongoUpdate}</update>
        <upsert>false</upsert>
        <collation></collation>
        <arrayFilters></arrayFilters>
        <responseVariable>mongodb_updateOne_1</responseVariable>
        <overwriteBody>true</overwriteBody>
    </mongodb.updateOne>
    <filter source="json-eval($.modifiedCount)" regex="^(?!0$).*">
        <then>
            <payloadFactory description="Response poayload" media-type="json" template-type="Default">
                <format>
                    {
                    "lossItemIdentifier": "$1",
                    "isSuccessful": "true",
                    "message": "Loss status updated successfully"
                    }
                </format>
                <args>
                    <arg expression="json-eval($ctx:initPayload.lossItemIdentifier)" evaluator="json"/>
                </args>
            </payloadFactory>
        </then>
        <else>
        <propertyGroup description="error details">
            <property value="404" name="ERROR_CODE" scope="default" type="STRING"/>
            <property value="Update failed" name="ERROR_MESSAGE" scope="default" type="STRING"/>
            <property value="Failed to update Loss Status" name="ERROR_DETAIL" scope="default" type="STRING"/>
            </propertyGroup>
        <call-template description="Error Log" target="Common-Log-Template-V1">
            <with-param name="service" value="claim-assessment-sapi"/>
            <with-param name="sequence" value="claim-assessment-sapi-updateLossStatusByClaimId-sequence"/>
            <with-param name="level" value="INFO"/>
            <with-param name="message" value="{$ctx:ERROR_MESSAGE}"/>
            <with-param name="status" value="ERROR"/>
            </call-template>
            <sequence key="claim-assessment-sapi-fault-sequence" />
        </else>
    </filter>
    <property name="LatencyMs" expression="get-property('SYSTEM_TIME') - get-property('StartTime')"/>
	<call-template target="Common-Log-Template-V1">
        <with-param name="service" value="claim-assessment-sapi"/>
        <with-param name="sequence" value="claim-assessment-sapi-updateLossStatusByClaimId-sequence"/>
        <with-param name="level" value="INFO"/>
        <with-param name="message" value="END claim-assessment-sapi-updateLossStatusByClaimId-sequence"/>
        <with-param name="status" value="Ended"/>
    </call-template>
</sequence>