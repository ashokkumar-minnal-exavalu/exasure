<?xml version="1.0" encoding="UTF-8"?>
<sequence name="claim-coverage-sapi-get-allCoverages-sequence" trace="disable" xmlns="http://ws.apache.org/ns/synapse">
 <property name="claimId" expression="get-property('uri.var.claimId')" scope="default" type="STRING"/>
    
<call-template target="Common-Log-Template-V1" description="start-log">
        <with-param name="service" value="claim-coverage-sapi"/>
        <with-param name="sequence" value="claim-coverage-sapi-get-allCoverages-sequence"/>
        <with-param name="level" value="INFO"/>
        <with-param name="message" value="{fn:concat('Initiating claim-coverage-sapi-get-allCoverages-sequence for claimId- ', $ctx:uri.var.claimId)}"/>
        <with-param name="status" value="START"/>
    </call-template>
	    <property name="updateQuery" expression="fn:concat('{&quot;claimId&quot;:&quot;', $ctx:claimId, '&quot;}')"/>
<mongodb.find configKey="WSO2-MongoDB-Connection">
        <collection>claimCoverages</collection>
        <query>{$ctx:updateQuery}</query>
        <projection></projection>
        <collation></collation>
        <limit></limit>
        <sort></sort>
        <responseVariable>mongodb_find_1</responseVariable>
        <overwriteBody>true</overwriteBody>
    </mongodb.find>
    
    <filter source="json-eval($.found)" regex="true">
        <then>
            <!-- SUCCESS SCENARIO -->
            <enrich>
                <source type="custom" xpath="json-eval($.data)"/>
                <target type="body" action="replace"/>
            </enrich>
            <script language="js"><![CDATA[var payload = mc.getPayloadJSON();

payload.forEach(function(item){
    delete item._id;
});

mc.setPayloadJSON(payload);]]></script>
        </then>
        <else>
            <!-- ERROR SCENARIO -->
            <property name="messageType" value="application/json" scope="axis2"/>
            <property name="HTTP_SC" value="404" scope="axis2"/>
            <payloadFactory media-type="json">
                <format>
                    {
                    "errorCode": "404",
                    "errorMessage": "Data not found",
                    "errorDetails": "The data requested is not found in database.",
                    "transactionId": "$1",
                    "timeStamp": "$2"
                    }
                </format>
                <args>
                    <arg expression="get-property('correlation_id')"/>
                    <arg expression="get-property('SYSTEM_DATE')"/>
                </args>
            </payloadFactory>
        </else>
    </filter>
    
	<call-template target="Common-Log-Template-V1" description="end-log">
        <with-param name="service" value="claim-coverage-sapi"/>
        <with-param name="sequence" value="claim-coverage-sapi-get-allCoverages-sequence"/>
        <with-param name="level" value="INFO"/>
        <with-param name="message" value="{fn:concat('Ending claim-coverage-sapi-get-allCoverages-sequence for claimId- ', $ctx:uri.var.claimId)}"/>
        <with-param name="status" value="END"/>
    </call-template>
    <respond/>
</sequence>