<sequence name="claim-papi-updateReserve-sequence" trace="disable" xmlns="http://ws.apache.org/ns/synapse">

    <propertyGroup description="apiProperty">
        <property name="CorrelationID" expression="get-property('correlation_id')"/>
        <property name="LatencyMs" scope="default" type="STRING" value="0"/>
        <property name="StartTime" expression="get-property('SYSTEM_TIME')"/>
        <property name="claimId" expression="get-property('uri.var.claimId')"/>
    </propertyGroup>
    <call-template target="Common-Log-Template-V1">
        <with-param name="service" value="claim-papi"/>
        <with-param name="sequence" value="claim-papi-updateReserve-sequence"/>
        <with-param name="level" value="INFO"/>
        <with-param name="message" value="Start claim-papi-updateReserve-sequence"/>
        <with-param name="status" value="START"/>
    </call-template>
    <propertyGroup>
        <property name="HTTP_METHOD" scope="axis2" value="GET"/>
        <property name="REST_URL_POSTFIX" scope="axis2" expression="fn:concat('/api/claim/', get-property('claimId'), '/inspection-reports')"/>
    </propertyGroup>
    <call>
        <endpoint key="claim-assessment-sapi-restEndpoint"/>
    </call>
    <propertyGroup>
        <property name="inspectionsResponse" expression="json-eval($)" scope="default"/>
        <property name="inspectionStatus" expression="json-eval($.inspectionStatus)"/>
        <property name="inspectionDate" expression="json-eval($.adjusterDetails.inspectionDate)"/>
        <property name="netPayableAmount" expression="json-eval($.assessment.netPayableAmount)"/>
        <property name="inspectionCurrency" expression="json-eval($.assessment.currencyCode)"/>
        <property name="inspectionRemarks" expression="json-eval($.inspectionOutcome.remarks)"/>
    </propertyGroup>
    <propertyGroup>
        <property name="HTTP_METHOD" scope="axis2" value="GET"/>
        <property name="REST_URL_POSTFIX" scope="axis2" expression="fn:concat('/api/claim/', get-property('claimId'), '/loss-items')"/>
    </propertyGroup>
    <call>
        <endpoint key="claim-assessment-sapi-restEndpoint"/>
    </call>
    <propertyGroup>
        <property name="lossitemsResponse" expression="json-eval($.data[0])" scope="default"/>
        <property name="lossItemIdentifier" expression="json-eval($.data[0].lossItemIdentifier)"/>
    </propertyGroup>
    <propertyGroup>
        <property name="HTTP_METHOD" scope="axis2" value="GET"/>
        <property name="REST_URL_POSTFIX" scope="axis2" expression="fn:concat('/api/claim/', get-property('claimId'), '/reserves')"/>
    </propertyGroup>
    <call>
        <endpoint key="reserve-management-sapi-restEndpoint"/>
    </call>
    <propertyGroup>
        <property name="reserveResponse" expression="json-eval($.data[0])" scope="default"/>
        <property name="reserveStatus" expression="json-eval($.data[0].reserveStatus)"/>
        <property name="relatedLossItemIdentifier" expression="json-eval($.data[0].relatedLossItemIdentifier)"/>
        <property name="reserveCreatedDate" expression="json-eval($.data[0].reserveCreatedDate)"/>
        <property name="reserveAmount" expression="json-eval($.data[0].reserveAmount.amount)"/>
        <property name="reserveCurrency" expression="json-eval($.data[0].reserveAmount.currency)"/>
    </propertyGroup>
<log level="custom">
    <property name="OUT_reserveResponse" expression="$ctx:reserveResponse"/>
    <property name="OUT_lossitemsResponse" expression="$ctx:lossitemsResponse"/>
    <property name="OUT_inspectionsResponse" expression="$ctx:inspectionsResponse"/>
    <property name="reserveStatus+++++" expression="$ctx:reserveStatus"/>
    <property name="lossItemIdentifier++++" expression="$ctx:lossItemIdentifier"/>
    <property name="relatedLossItemIdentifier" expression="$ctx:relatedLossItemIdentifier"/>
    <property name="inspectionStatus" expression="$ctx:inspectionStatus"/>
    <property name="inspectionDate" expression="$ctx:inspectionDate"/>
    <property name="reserveCreatedDate" expression="$ctx:reserveCreatedDate"/>
</log>
<script language="js"><![CDATA[
    var reserveStatus = mc.getProperty("reserveStatus");
    var lossId        = mc.getProperty("lossItemIdentifier");
    var reserveLossId = mc.getProperty("relatedLossItemIdentifier");
    var inspStatus    = mc.getProperty("inspectionStatus");
    var inspDate      = mc.getProperty("inspectionDate");
    var reserveDate   = mc.getProperty("reserveCreatedDate");

    var valid = true;
    var error = null;

    // 1. Reserve ACTIVE
    if (reserveStatus !== "ACTIVE") {
        valid = false;
        error = "For Active reserve only adjustment will apply";
    }

    // 2. Loss match
    else if (lossId !== reserveLossId) {
        valid = false;
        error = "related LossItemIdentifier must match reserve relatedLossItemIdentifier";
    }

    // 3. Inspection approved
    else if (inspStatus !== "APPROVED") {
        valid = false;
        error = "reserve adjustment applicable only for approved inspection";
    }

    // 4. Date validation
    else if (new Date(inspDate) < new Date(reserveDate)) {
        valid = false;
        error = "inspectionDate should be greater than reserveCreatedDate";
    }

    mc.setProperty("validationValid", valid);
    mc.setProperty("validationError", error);

]]></script>
<filter xpath="$ctx:validationValid = false">
    <then>
        <propertyGroup description="error details">
            <property value="404" name="ERROR_CODE" scope="default" type="STRING"/>
            <property value="INVALID_INPUT" name="ERROR_MESSAGE" scope="default" type="STRING"/>
            <property name="ERROR_DETAIL" expression="get-property('validationError')"/>
        </propertyGroup>
        <call-template description="Error Log" target="Common-Log-Template-V1">
            <with-param name="service" value="claim-papi"/>
            <with-param name="sequence" value="claim-papi-updateReserve-sequence"/>
            <with-param name="level" value="INFO"/>
            <with-param name="message" value="{$ctx:ERROR_MESSAGE}"/>
            <with-param name="status" value="ERROR"/>
        </call-template>
        <sequence key="claim-papi-common-fault-sequence"/>
    </then>
    <else>
<log level="custom">
    <property name="DEBUG_reserveAmount***************" expression="$ctx:reserveAmount"/>
    <property name="DEBUG_netPayableAmount*************" expression="$ctx:netPayableAmount"/>
</log>
<script language="js"><![CDATA[
var reserveAmount = parseFloat(mc.getProperty("reserveAmount")) || 0;
var netPayable    = parseFloat(mc.getProperty("netPayableAmount")) || 0;

print("DEBUG reserveAmount: " + reserveAmount);
print("DEBUG netPayable: " + netPayable);

var reserveCurrency = mc.getProperty("reserveCurrency");
var currency        = mc.getProperty("inspectionCurrency");

var remarks         = mc.getProperty("inspectionRemarks");
var inspectionDate  = mc.getProperty("inspectionDate");
var lossId          = mc.getProperty("lossItemIdentifier");

var adjustAmount = netPayable;
var adjustmentType = adjustAmount > 0 ? "DECREASE" : "INCREASE";

// keep amount positive for output
var finalAmount = Math.abs(adjustAmount);

var output = {
    adjustmentType: adjustmentType,
    previousReserveAmount: {
        amount: reserveAmount,
        currency: reserveCurrency
    },
    currentReserveAmount: {
        amount: reserveAmount - netPayable,
        currency: currency
    },
    adjustmentAmount: {
        amount: finalAmount,
        currency: currency
    },
    reason: remarks,
    adjustmentEffectiveDate: inspectionDate,
    updatedBy: "ADJUSTER",
    relatedLossItemIdentifier: lossId
};

mc.setPayloadJSON(output);

]]></script>
    <propertyGroup>
        <property name="HTTP_METHOD" scope="axis2" value="PATCH"/>
        <property name="REST_URL_POSTFIX" scope="axis2" expression="fn:concat('/api/claim/', get-property('claimId'), '/reserves')"/>
    </propertyGroup>
    <call>
        <endpoint key="reserve-management-sapi-restEndpoint"/>
    </call>
    </else>
</filter>
    <property name="LatencyMs" expression="get-property('SYSTEM_TIME') - get-property('StartTime')"/>
    <call-template target="Common-Log-Template-V1">
        <with-param name="service" value="claim-papi"/>
        <with-param name="sequence" value="claim-papi-updateReserve-sequence"/>
        <with-param name="level" value="INFO"/>
        <with-param name="message" value="Ended claim-papi-updateReserve-sequence"/>
        <with-param name="status" value="End"/>
    </call-template>
</sequence>