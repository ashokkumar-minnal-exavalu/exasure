<?xml version="1.0" encoding="UTF-8"?>
<sequence name="claim-papi-getClaimByClaimIdSequence" xmlns="http://ws.apache.org/ns/synapse">
	<call-template target="Common-Log-Template-V1" description="start-log">
        <with-param name="service" value="claim-api"/>
        <with-param name="sequence" value="claim-papi-getClaimByClaimIdSequence"/>
        <with-param name="level" value="INFO"/>
        <with-param name="message" value="Initiating claim-papi-getClaimByClaimIdSequence"/>
        <with-param name="status" value="START"/>
    </call-template>
    <property name="claimId" expression="get-property('uri.var.claimId')"/>
	<propertyGroup description="inputProperties">
        <property name="HTTP_METHOD" scope="axis2" type="STRING" value="GET"/>
        <property name="REST_URL_POSTFIX" scope="axis2" type="STRING" expression="concat('/claim/',  $ctx:claimId)"/>
    </propertyGroup>
	<call>
        <endpoint key="claim-sapi-restEndpoint"/>
    </call>
    <log category="INFO" logMessageID="true" logFullPayload="true">
        <message>Response from retrieve claims SAPI rest endpoint++++++++</message>
    </log>
	<!-- Initialize documents array -->
    <property name="documents" value="[]" scope="default" type="STRING"/>	
	<filter source="get-property('axis2','HTTP_SC')" regex="2\d{2}">
		<then>
			<foreach collection="${$.data[0].claimRequest.accidentDetails.images}" parallel-execution="true" update-original="true" continue-without-aggregation="false">
				<sequence>
					<script language="js"><![CDATA[
					var id = mc.getPayloadJSON();
					mc.setProperty("documentID", id);
					]]></script>							
					<property name="HTTP_METHOD" value="GET" scope="axis2"/>
					<property name="REST_URL_POSTFIX" scope="axis2" type="STRING" expression="fn:concat('/api/document/', get-property('documentID'))"/>
					<call blocking="true">
						<endpoint key="document-sapi-restEndpoint"/>
                    </call>
					<log category="INFO" logMessageID="true" logFullPayload="true">
						<message>Response from retrieve documents SAPI rest endpoint++++++++</message>
					</log>					
                    <!-- Append document -->
                    <script language="js"><![CDATA[
                        var docs = mc.getProperty("documents");
                        docs = docs ? JSON.parse(docs) : [];
                        docs.push(mc.getPayloadJSON());

                        mc.setProperty("documents", JSON.stringify(docs));
                    ]]></script>
                </sequence>
            </foreach>		
            <!-- Final Transformation -->
			<script language="js"><![CDATA[
				var payload = mc.getPayloadJSON();
				var claim = payload.data[0].claimRequest;

				// Replace images already handled in foreach (no change needed here)

				// Rename pinCode → zipCode
				if (claim.incidentLocation && claim.incidentLocation.address) {
					var addr = claim.incidentLocation.address;

					if (addr.pinCode) {
						addr.zipCode = addr.pinCode;
						delete addr.pinCode;
					}
				}

				mc.setPayloadJSON([claim]);
			]]></script>			
        </then>
		<else>
            <!-- FAILURE FLOW -->
            <!-- Just respond with backend response -->
			<respond/>
        </else>
    </filter>
	<call-template target="Common-Log-Template-V1" description="end-log">
		<with-param name="service" value="claim-api"/>
		<with-param name="sequence" value="claim-papi-getClaimByClaimIdSequence"/>
		<with-param name="level" value="INFO"/>
		<with-param name="message" value="Ending claim-papi-getClaimByClaimIdSequence"/>
		<with-param name="status" value="END"/>
    </call-template>
</sequence>