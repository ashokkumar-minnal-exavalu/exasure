<?xml version="1.0" encoding="UTF-8"?>
<sequence name="get-billing-transactions-billing-payment-papi-sequence" trace="disable" xmlns="http://ws.apache.org/ns/synapse">
    <propertyGroup description="apiProperty">
        <property name="CorrelationID" expression="get-property('correlation_id')"/>
        <property name="LatencyMs" scope="default" type="STRING" value="0"/>
        <property name="StartTime" expression="get-property('SYSTEM_TIME')"/>
    </propertyGroup>

    <call-template target="Common-Log-Template-V1">
        <with-param name="service" value="billing-payment-papi-api"/>
        <with-param name="sequence" value="get-billing-transactions-billing-payment-papi-sequence"/>
        <with-param name="level" value="INFO"/>
        <with-param name="message" value="Started get-billing-transactions-billing-payment-papi-sequence"/>
        <with-param name="status" value="START"/>
    </call-template>

    <!-- Extract quoteId from incoming payload -->
    <property name="quoteId" expression="json-eval($.quoteId)" scope="default" type="STRING"/>

    <log category="INFO" logMessageID="false">
        <message>Extracted quoteId for billing lookup</message>
        <property name="quoteId" expression="$ctx:quoteId"/>
    </log>

    <propertyGroup description="inputProperty">
        <property name="HTTP_METHOD" scope="axis2" type="STRING" value="GET"/>
        <property name="REST_URL_POSTFIX" scope="axis2" expression="fn:concat('/retrive-payment/', $ctx:quoteId)" type="STRING"/>
    </propertyGroup>

    <call>
        <endpoint key="billing-payment-sapi-restEndpoint"/>
    </call>

    <log category="INFO" logMessageID="true" logFullPayload="true">
        <message>Response from billing-payment-sapi++++++</message>
    </log>

    <property name="LatencyMs" expression="get-property('SYSTEM_TIME') - get-property('StartTime')"/>
    <call-template target="Common-Log-Template-V1">
        <with-param name="service" value="billing-payment-papi-api"/>
        <with-param name="sequence" value="get-billing-transactions-billing-payment-papi-sequence"/>
        <with-param name="level" value="INFO"/>
        <with-param name="message" value="Ended get-billing-transactions-billing-payment-papi-sequence"/>
        <with-param name="status" value="END"/>
    </call-template>
</sequence>