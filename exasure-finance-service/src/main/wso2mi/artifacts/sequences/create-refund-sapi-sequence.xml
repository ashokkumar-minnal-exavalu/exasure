<?xml version="1.0" encoding="UTF-8"?>
<sequence name="create-refund-sapi-sequence" trace="disable" xmlns="http://ws.apache.org/ns/synapse">
    <propertyGroup description="apiProperty">
        <property name="CorrelationID" expression="get-property('correlation_id')"/>
        <property name="LatencyMs" scope="default" type="STRING" value="0"/>
        <property name="StartTime" expression="get-property('SYSTEM_TIME')"/>
    </propertyGroup>
    <call-template target="Common-Log-Template-V1">
        <with-param name="service" value="refund-sapi-api"/>
        <with-param name="sequence" value="create-refund-sapi-sequence"/>
        <with-param name="level" value="INFO"/>
        <with-param name="message" value="Started create-refund-sapi-sequence"/>
        <with-param name="status" value="START"/>
    </call-template>

    <!-- Extract values into properties BEFORE payloadFactory overwrites the payload -->
    <script language="js">
        var payload = mc.getPayloadJSON();
        mc.setProperty("finalAmount", Math.round(payload.amount * 100));
        mc.setProperty("chargeId", payload.chargeId);
    </script>

    <!-- FIX: Use media-type="json" like the working token sequence.
         WSO2's XFormURLEncodedFormatter converts JSON key-value pairs
         to form-encoded format when messageType is set below. -->
    <payloadFactory media-type="json">
        <format>
            {
                "amount": "$1",
                "charge": "$2"
            }
        </format>
        <args>
            <arg expression="$ctx:finalAmount"/>
            <arg expression="$ctx:chargeId"/>
        </args>
    </payloadFactory>

    <!-- Set form-urlencoded — formatter converts the JSON above to amount=...&charge=... -->
    <propertyGroup>
        <property name="messageType" value="application/x-www-form-urlencoded" scope="axis2"/>
        <property name="ContentType" value="application/x-www-form-urlencoded" scope="axis2"/>
    </propertyGroup>

    <log category="INFO" logMessageID="true" logFullPayload="true">
        <message>payload set for stripe api call+++++++++</message>
    </log>

    <header name="Authorization" scope="transport" value="Bearer sk_test_51SdNv2Qsuyht91JMrQw97hGiY8ZGLbcdm0vdxQyd75JIqv0KX8n6I6oh9iec8Wu5VOO9OD6610K4ulsGAL6fwYSC00tKjpLaSa"/>
    <header name="Client-Type" value="application/x-www-form-urlencoded" scope="transport"/>

    <!-- Remove any existing REST_URL_POSTFIX first, then set fresh (same pattern as working sequence) -->
    <propertyGroup>
        <property name="REST_URL_POSTFIX" action="remove" scope="axis2"/>
        <property name="DISABLE_CHUNKING" value="true" scope="axis2"/>
    </propertyGroup>
    <propertyGroup description="inputProperties">
        <property name="HTTP_METHOD" scope="axis2" type="STRING" value="POST"/>
        <property name="REST_URL_POSTFIX" scope="axis2" type="STRING" value="/v1/refunds"/>
    </propertyGroup>

    <call>
        <endpoint key="stripe-api-restEndpoint"/>
    </call>

    <log category="INFO" logMessageID="true" logFullPayload="true">
        <message>response received from stripe api call+++++++++</message>
    </log>

    <!-- Extract and convert refund amount back from cents -->
    <property name="refundAmount" expression="json-eval($.amount)" scope="default"/>
    <script language="js">
        var rawAmount = mc.getProperty("refundAmount");
        mc.setProperty("refundAmountFinal", parseFloat(rawAmount) / 100);
    </script>

    <!-- Transform: Map Stripe response to standard refund payload -->
    <payloadFactory media-type="json">
        <format>
        {
            "refundId": "$1",
            "transactionId": "$2",
            "paymentIntentId": "$3",
            "refundAmount": $4,
            "currency": "$5",
            "createdDate": "$6",
            "status": "$7"
        }
        </format>
        <args>
            <arg evaluator="json" expression="$.id"/>
            <arg evaluator="json" expression="$.charge"/>
            <arg evaluator="json" expression="$.payment_intent"/>
            <arg expression="$ctx:refundAmountFinal"/>
            <arg evaluator="json" expression="$.currency"/>
            <arg evaluator="json" expression="$.created"/>
            <arg evaluator="json" expression="$.status"/>
        </args>
    </payloadFactory>

    <property name="LatencyMs" expression="get-property('SYSTEM_TIME') - get-property('StartTime')"/>
    <call-template target="Common-Log-Template-V1">
        <with-param name="service" value="refund-sapi-api"/>
        <with-param name="sequence" value="create-refund-sapi-sequence"/>
        <with-param name="level" value="INFO"/>
        <with-param name="message" value="Ended create-refund-sapi-sequence"/>
        <with-param name="status" value="END"/>
    </call-template>
</sequence>
