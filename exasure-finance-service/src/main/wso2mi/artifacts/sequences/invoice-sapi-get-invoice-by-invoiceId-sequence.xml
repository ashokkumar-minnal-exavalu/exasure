<?xml version="1.0" encoding="UTF-8"?>
<sequence name="invoice-sapi-get-invoice-by-invoiceId-sequence" xmlns="http://ws.apache.org/ns/synapse">
    <propertyGroup description="apiProperty">
        <property name="CorrelationID" expression="get-property('correlation_id')"/>
        <property name="LatencyMs" scope="default" type="STRING" value="0"/>
        <property name="StartTime" expression="get-property('SYSTEM_TIME')"/>
        <property name="invoiceId" expression="get-property('uri.var.invoiceId')"/>
    </propertyGroup>
    <call-template target="Common-Log-Template-V1" description="start-log">
        <with-param name="service" value="invoice-spi"/>
        <with-param name="sequence" value="invoice-sapi-get-invoice-by-invoiceId-sequence"/>
        <with-param name="level" value="INFO"/>
        <with-param name="message" value="{fn:concat('Initiating invoice-sapi-get-invoice-by-invoiceId-sequencee for invoiceId- ', $ctx:uri.var.invoiceId)}"/>
        <with-param name="status" value="START"/>
    </call-template>
    <property name="updateQuery" expression="fn:concat('{&quot;invoiceId&quot;:&quot;', $ctx:invoiceId, '&quot;}')"/>
    <mongodb.findOne configKey="WSO2-MongoDB-Connection">
        <collection>Invoice</collection>
        <query>{$ctx:updateQuery}</query>
        <projection></projection>
        <collation></collation>
        <responseVariable>quoteDetailsResult</responseVariable>
        <overwriteBody>true</overwriteBody>
    </mongodb.findOne>
    <log category="INFO" logMessageID="false" logFullPayload="false">
        <message>LOG</message>
        <property name="InvoiceId" expression="json-eval($)"/>
    </log>
    <filter source="json-eval($.found)" regex="true">
        <then>
            <!-- SUCCESS SCENARIO -->
            <script language="js"><![CDATA[
var response = mc.getPayloadJSON();

// Ensure data object exists
if (response && response.data) {

    var dataObj = response.data;

    // Remove _id if present
    if (dataObj._id) {
        delete dataObj._id;
    }

    // Set cleaned object as final payload
    mc.setPayloadJSON(dataObj);
}
]]></script>
        </then>
        <else>
            <!-- ERROR SCENARIO -->
            <property name="messageType" value="application/json" scope="axis2"/>
            <property name="HTTP_SC" value="404" scope="axis2"/>
            <payloadFactory media-type="json">
                <format>
                    {
                    "errorCode": "404",
                    "errorMessage": "Data not found",
                    "errorDetails": "Invoice not found for the given invoiceId.",
                    "transactionId": "$1",
                    "timeStamp": "$2"
                    }
                </format>
                <args>
                    <arg expression="get-property('correlation_id')"/>
                    <arg expression="get-property('SYSTEM_DATE')"/>
                </args>
            </payloadFactory>
        </else>
    </filter>
    <call-template target="Common-Log-Template-V1" description="end-log">
        <with-param name="service" value="invoice-sapi"/>
        <with-param name="sequence" value="invoice-sapi-get-invoice-by-invoiceId-sequence"/>
        <with-param name="level" value="INFO"/>
        <with-param name="message" value="{fn:concat('Ending invoice-sapi-get-invoice-by-invoiceId-sequence for invoiceId- ', $ctx:uri.var.invoiceId)}"/>
        <with-param name="status" value="END"/>
    </call-template>
</sequence>