<?xml version="1.0" encoding="UTF-8"?>
<sequence name="claim-payment-sapi-create-payout-sequence" trace="disable" xmlns="http://ws.apache.org/ns/synapse">
   <propertyGroup description="apiProperty">
        <property name="CorrelationID" expression="get-property('correlation_id')"/>
        <property name="LatencyMs" scope="default" type="STRING" value="0"/>
        <property name="StartTime" expression="get-property('SYSTEM_TIME')"/>
        <property name="claimAmount" expression="json-eval($.claimAmount)"/>
        <property name="currency" expression="json-eval($.currency)"/>
        <property name="payoutDestinationId" expression="json-eval($.payoutDestinationId)"/>
    </propertyGroup>
    <call-template target="Common-Log-Template-V1">
        <with-param name="service" value="claim-payment-sapi"/>
        <with-param name="sequence" value="claim-payment-sapi-create-payout-sequence"/>
        <with-param name="level" value="INFO"/>
        <with-param name="message" value="Started claim-payment-sapi-create-payout-sequence"/>
        <with-param name="status" value="START"/>
    </call-template>
    <payloadFactory media-type="json">
        <format>
            {
            "amount": "$1",
            "currency": "$2",
            "destination": "ba_1SdNvVQsuyht91JMkTpux2HQ"
            }
        </format>
        <args>
            <arg evaluator="xml" expression="get-property('claimAmount')"/>
            <arg evaluator="xml" expression="get-property('currency')"/>
        </args>
    </payloadFactory>
<propertyGroup>
    <property name="messageType" value="application/x-www-form-urlencoded" scope="axis2"/>
    <property name="ContentType" value="application/x-www-form-urlencoded" scope="axis2"/>
</propertyGroup>
        <!-- Auth header -->
    <header name="Authorization" scope="transport" value="Bearer sk_test_51SdNv2Qsuyht91JMrQw97hGiY8ZGLbcdm0vdxQyd75JIqv0KX8n6I6oh9iec8Wu5VOO9OD6610K4ulsGAL6fwYSC00tKjpLaSa"/>
    <propertyGroup>
        <property name="REST_URL_POSTFIX" action="remove" scope="axis2"/>
        <property name="DISABLE_CHUNKING" value="true" scope="axis2"/>
    </propertyGroup>
	<propertyGroup description="inputProperties">
        <property name="HTTP_METHOD" scope="axis2" type="STRING" value="POST"/>
        <property name="REST_URL_POSTFIX" scope="axis2"  value="/v1/payouts"/>
    </propertyGroup>
	<call>
        <endpoint key="stripe-api-restEndpoint"/>
    </call> 
<propertyGroup>
    <property name="messageType" value="application/json" scope="axis2"/>
    <property name="ContentType" value="application/json" scope="axis2"/>
    <property name="HTTP_SC" value="201" scope="axis2"/>
</propertyGroup>
	<filter source="get-property('axis2','HTTP_SC')" regex="^(200|201)$">
        <then>
<payloadFactory media-type="json">
    <format>
        {
          "paymentId": "$1",
          "transactionDetails": {
            "amount": $2,
            "currency": "$3",
            "method": "$4",
            "payoutDestinationId": "$5",
            "dateTime": "$6",
            "status": "$7"
          }
        }
    </format>
    <args>
        <arg evaluator="json" expression="$.id"/>
        <arg evaluator="json" expression="$.amount"/>
        <arg evaluator="json" expression="$.currency"/>
        <arg evaluator="json" expression="$.method"/>
        <arg evaluator="json" expression="$.destination"/>
        <arg evaluator="xml" expression="get-property('SYSTEM_DATE', 'dd-MM-yyyy HH:mm:ss')"/>
        <arg evaluator="json" expression="$.status"/>
    </args>
</payloadFactory>
        </then>
        <else>
           <payloadFactory media-type="json">
                <format>
                    {
                    "errorCode": "$1",
                    "errorMessage": "$2",
                    "transactionId": "$3",
                    "timeStamp": "$4"
                    }
                </format>
                <args>
                    <arg expression="get-property('axis2','HTTP_SC')"/>
                    <arg expression="get-property('ERROR_MESSAGE')"/>
                    <arg expression="get-property('uuid')"/>
                    <arg expression="fn:current-dateTime()"/>
                </args>
            </payloadFactory>
        </else>
    </filter>
<property name="LatencyMs" expression="get-property('SYSTEM_TIME') - get-property('StartTime')"/>
    <call-template target="Common-Log-Template-V1">
        <with-param name="service" value="claim-payment-sapi"/>
        <with-param name="sequence" value="claim-payment-sapi-create-payout-sequence"/>
        <with-param name="level" value="INFO"/>
        <with-param name="message" value="END claim-payment-sapi-create-payout-sequence"/>
        <with-param name="status" value="Ended"/>
    </call-template>
</sequence>